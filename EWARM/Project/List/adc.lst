    238          void ADC_ResultFilter(void)
    239          {
    240          	uint32_t sum = 0;
    241          	uint16_t i, j;
    242          
    243          	for (i = 0;i < ADC_SAMP_CH_MAX;i++)
    244          	{
    245          		sum = 0;
    246          		for (j = 0;j < ADC_SAMP_NUM;j++)
    247          		{
    248          			sum += uhADCxConvertedValue[j][i];
    249          		}
    250          		ADC_Result[i] = sum / ADC_SAMP_NUM;
    251          	}
    252          }
    253          
    254          
    255          void Get_Battery_Voltage(void)
    256          {
    257              uint16_t filtered_adc_value;
    258          
    259          
    260              filtered_adc_value = ADC_Result[0];
    261          
    262              // ŒÆËă”çłŰ”çŃč
    263              battery_voltage = (float)filtered_adc_value * 3.3 / 4096.0 * (R1 + R2) / R2;
    264          
    265          
    266          }
