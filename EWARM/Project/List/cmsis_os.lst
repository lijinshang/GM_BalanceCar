   1548          
   1549          /**
   1550          * @brief  Receive an item from a queue without removing the item from the queue.
   1551          * @param  queue_id  message queue ID obtained with \ref osMessageCreate.
   1552          * @param  millisec  timeout value or 0 in case of no time-out.
   1553          * @retval event information that includes status code.
   1554          */
   1555          osEvent osMessagePeek (osMessageQId queue_id, uint32_t millisec)
   1556          {
   1557            TickType_t ticks;
   1558            osEvent event;
   1559            
   1560            event.def.message_id = queue_id;
   1561            
   1562            if (queue_id == NULL) {
   1563              event.status = osErrorParameter;
   1564              return event;
   1565            }
   1566            
   1567            ticks = 0;
   1568            if (millisec == osWaitForever) {
   1569              ticks = portMAX_DELAY;
   1570            }
   1571            else if (millisec != 0) {
   1572              ticks = millisec / portTICK_PERIOD_MS;
   1573              if (ticks == 0) {
   1574                ticks = 1;
   1575              }
   1576            }
   1577            
   1578            if (xQueuePeek(queue_id, &event.value.v, ticks) == pdTRUE) 
   1579            {
   1580              /* We have mail */
   1581              event.status = osEventMessage;
   1582            }
   1583            else 
   1584            {
   1585              event.status = (ticks == 0) ? osOK : osEventTimeout;
   1586            }
   1587            
   1588            return event;
   1589          }
