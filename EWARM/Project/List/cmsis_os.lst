    856          
    857          #endif    /* Use Semaphores */
    858          
    859          /*******************   Memory Pool Management Functions  ***********************/
    860          
    861          #if (defined (osFeature_Pool)  &&  (osFeature_Pool != 0)) 
    862          
    863          //TODO
    864          //This is a primitive and inefficient wrapper around the existing FreeRTOS memory management.
    865          //A better implementation will have to modify heap_x.c!
    866          
    867          
    868          typedef struct os_pool_cb {
    869            void *pool;
    870            uint8_t *markers;
    871            uint32_t pool_sz;
    872            uint32_t item_sz;
    873            uint32_t currentIndex;
    874          } os_pool_cb_t;
    875          
    876          
    877          /**
    878          * @brief Create and Initialize a memory pool
    879          * @param  pool_def      memory pool definition referenced with \ref osPool.
    880          * @retval  memory pool ID for reference by other functions or NULL in case of error.
    881          * @note   MUST REMAIN UNCHANGED: \b osPoolCreate shall be consistent in every CMSIS-RTOS.
    882          */
    883          osPoolId osPoolCreate (const osPoolDef_t *pool_def)
    884          {
    885          #if (configSUPPORT_DYNAMIC_ALLOCATION == 1)
    886            osPoolId thePool;
    887            int itemSize = 4 * ((pool_def->item_sz + 3) / 4);
    888            uint32_t i;
    889            
    890            /* First have to allocate memory for the pool control block. */
    891           thePool = pvPortMalloc(sizeof(os_pool_cb_t));
    892          
    893            
    894            if (thePool) {
    895              thePool->pool_sz = pool_def->pool_sz;
    896              thePool->item_sz = itemSize;
    897              thePool->currentIndex = 0;
    898              
    899              /* Memory for markers */
    900              thePool->markers = pvPortMalloc(pool_def->pool_sz);
    901             
    902              if (thePool->markers) {
    903                /* Now allocate the pool itself. */
    904               thePool->pool = pvPortMalloc(pool_def->pool_sz * itemSize);
    905                
    906                if (thePool->pool) {
    907                  for (i = 0; i < pool_def->pool_sz; i++) {
    908                    thePool->markers[i] = 0;
    909                  }
    910                }
    911                else {
    912                  vPortFree(thePool->markers);
    913                  vPortFree(thePool);
    914                  thePool = NULL;
    915                }
    916              }
    917              else {
    918                vPortFree(thePool);
    919                thePool = NULL;
    920              }
    921            }
    922          
    923            return thePool;
    924           
    925          #else
    926            return NULL;
    927          #endif
    928          }
    929          
    930          /**
    931          * @brief Allocate a memory block from a memory pool
    932          * @param pool_id       memory pool ID obtain referenced with \ref osPoolCreate.
    933          * @retval  address of the allocated memory block or NULL in case of no memory available.
    934          * @note   MUST REMAIN UNCHANGED: \b osPoolAlloc shall be consistent in every CMSIS-RTOS.
    935          */
    936          void *osPoolAlloc (osPoolId pool_id)
    937          {
    938            int dummy = 0;
    939            void *p = NULL;
    940            uint32_t i;
    941            uint32_t index;
    942            
    943            if (inHandlerMode()) {
    944              dummy = portSET_INTERRUPT_MASK_FROM_ISR();
    945            }
    946            else {
    947              vPortEnterCritical();
    948            }
    949            
    950            for (i = 0; i < pool_id->pool_sz; i++) {
    951              index = (pool_id->currentIndex + i) % pool_id->pool_sz;
    952              
    953              if (pool_id->markers[index] == 0) {
    954                pool_id->markers[index] = 1;
    955                p = (void *)((uint32_t)(pool_id->pool) + (index * pool_id->item_sz));
    956                pool_id->currentIndex = index;
    957                break;
    958              }
    959            }
    960            
    961            if (inHandlerMode()) {
    962              portCLEAR_INTERRUPT_MASK_FROM_ISR(dummy);
    963            }
    964            else {
    965              vPortExitCritical();
    966            }
    967            
    968            return p;
    969          }
    970          
    971          /**
    972          * @brief Allocate a memory block from a memory pool and set memory block to zero
    973          * @param  pool_id       memory pool ID obtain referenced with \ref osPoolCreate.
    974          * @retval  address of the allocated memory block or NULL in case of no memory available.
    975          * @note   MUST REMAIN UNCHANGED: \b osPoolCAlloc shall be consistent in every CMSIS-RTOS.
    976          */
    977          void *osPoolCAlloc (osPoolId pool_id)
    978          {
    979            void *p = osPoolAlloc(pool_id);
    980            
    981            if (p != NULL)
    982            {
    983              memset(p, 0, sizeof(pool_id->pool_sz));
    984            }
    985            
    986            return p;
    987          }
    988          
    989          /**
    990          * @brief Return an allocated memory block back to a specific memory pool
    991          * @param  pool_id       memory pool ID obtain referenced with \ref osPoolCreate.
    992          * @param  block         address of the allocated memory block that is returned to the memory pool.
    993          * @retval  status code that indicates the execution status of the function.
    994          * @note   MUST REMAIN UNCHANGED: \b osPoolFree shall be consistent in every CMSIS-RTOS.
    995          */
    996          osStatus osPoolFree (osPoolId pool_id, void *block)
    997          {
    998            uint32_t index;
    999            
   1000            if (pool_id == NULL) {
   1001              return osErrorParameter;
   1002            }
   1003            
   1004            if (block == NULL) {
   1005              return osErrorParameter;
   1006            }
   1007            
   1008            if (block < pool_id->pool) {
   1009              return osErrorParameter;
   1010            }
   1011            
   1012            index = (uint32_t)block - (uint32_t)(pool_id->pool);
   1013            if (index % pool_id->item_sz) {
   1014              return osErrorParameter;
   1015            }
   1016            index = index / pool_id->item_sz;
   1017            if (index >= pool_id->pool_sz) {
   1018              return osErrorParameter;
   1019            }
   1020            
   1021            pool_id->markers[index] = 0;
   1022            
   1023            return osOK;
   1024          }
   1025          
   1026          
   1027          #endif   /* Use Memory Pool Management */
   1028          
   1029          /*******************   Message Queue Management Functions  *********************/
   1030          
   1031          #if (defined (osFeature_MessageQ)  &&  (osFeature_MessageQ != 0)) /* Use Message Queues */
   1032          
   1033          /**
   1034          * @brief Create and Initialize a Message Queue
   1035          * @param queue_def     queue definition referenced with \ref osMessageQ.
   1036          * @param  thread_id     thread ID (obtained by \ref osThreadCreate or \ref osThreadGetId) or NULL.
   1037          * @retval  message queue ID for reference by other functions or NULL in case of error.
   1038          * @note   MUST REMAIN UNCHANGED: \b osMessageCreate shall be consistent in every CMSIS-RTOS.
   1039          */
   1040          osMessageQId osMessageCreate (const osMessageQDef_t *queue_def, osThreadId thread_id)
   1041          {
   1042            (void) thread_id;
   1043            
   1044          #if( configSUPPORT_STATIC_ALLOCATION == 1 ) && ( configSUPPORT_DYNAMIC_ALLOCATION == 1 )
   1045          
   1046            if ((queue_def->buffer != NULL) && (queue_def->controlblock != NULL)) {
   1047              return xQueueCreateStatic(queue_def->queue_sz, queue_def->item_sz, queue_def->buffer, queue_def->controlblock);
   1048            }
   1049            else {
   1050              return xQueueCreate(queue_def->queue_sz, queue_def->item_sz);
   1051            }
   1052          #elif ( configSUPPORT_STATIC_ALLOCATION == 1 )
   1053            return xQueueCreateStatic(queue_def->queue_sz, queue_def->item_sz, queue_def->buffer, queue_def->controlblock);
   1054          #else  
   1055            return xQueueCreate(queue_def->queue_sz, queue_def->item_sz);
   1056          #endif
   1057          }
   1058          
   1059          /**
   1060          * @brief Put a Message to a Queue.
   1061          * @param  queue_id  message queue ID obtained with \ref osMessageCreate.
   1062          * @param  info      message information.
   1063          * @param  millisec  timeout value or 0 in case of no time-out.
   1064          * @retval status code that indicates the execution status of the function.
   1065          * @note   MUST REMAIN UNCHANGED: \b osMessagePut shall be consistent in every CMSIS-RTOS.
   1066          */
   1067          osStatus osMessagePut (osMessageQId queue_id, uint32_t info, uint32_t millisec)
   1068          {
   1069            portBASE_TYPE taskWoken = pdFALSE;
   1070            TickType_t ticks;
   1071            
   1072            ticks = millisec / portTICK_PERIOD_MS;
   1073            if (ticks == 0) {
   1074              ticks = 1;
   1075            }
   1076            
   1077            if (inHandlerMode()) {
   1078              if (xQueueSendFromISR(queue_id, &info, &taskWoken) != pdTRUE) {
   1079                return osErrorOS;
   1080              }
   1081              portEND_SWITCHING_ISR(taskWoken);
   1082            }
   1083            else {
   1084              if (xQueueSend(queue_id, &info, ticks) != pdTRUE) {
   1085                return osErrorOS;
   1086              }
   1087            }
   1088            
   1089            return osOK;
   1090          }
   1091          
   1092          /**
   1093          * @brief Get a Message or Wait for a Message from a Queue.
   1094          * @param  queue_id  message queue ID obtained with \ref osMessageCreate.
   1095          * @param  millisec  timeout value or 0 in case of no time-out.
   1096          * @retval event information that includes status code.
   1097          * @note   MUST REMAIN UNCHANGED: \b osMessageGet shall be consistent in every CMSIS-RTOS.
   1098          */
   1099          osEvent osMessageGet (osMessageQId queue_id, uint32_t millisec)
   1100          {
   1101            portBASE_TYPE taskWoken;
   1102            TickType_t ticks;
   1103            osEvent event;
   1104            
   1105            event.def.message_id = queue_id;
   1106            event.value.v = 0;
   1107            
   1108            if (queue_id == NULL) {
   1109              event.status = osErrorParameter;
   1110              return event;
   1111            }
   1112            
   1113            taskWoken = pdFALSE;
   1114            
   1115            ticks = 0;
   1116            if (millisec == osWaitForever) {
   1117              ticks = portMAX_DELAY;
   1118            }
   1119            else if (millisec != 0) {
   1120              ticks = millisec / portTICK_PERIOD_MS;
   1121              if (ticks == 0) {
   1122                ticks = 1;
   1123              }
   1124            }
   1125            
   1126            if (inHandlerMode()) {
   1127              if (xQueueReceiveFromISR(queue_id, &event.value.v, &taskWoken) == pdTRUE) {
   1128                /* We have mail */
   1129                event.status = osEventMessage;
   1130              }
   1131              else {
   1132                event.status = osOK;
   1133              }
   1134              portEND_SWITCHING_ISR(taskWoken);
   1135            }
   1136            else {
   1137              if (xQueueReceive(queue_id, &event.value.v, ticks) == pdTRUE) {
   1138                /* We have mail */
   1139                event.status = osEventMessage;
   1140              }
   1141              else {
   1142                event.status = (ticks == 0) ? osOK : osEventTimeout;
   1143              }
   1144            }
   1145            
   1146            return event;
   1147          }
   1148          
   1149          #endif     /* Use Message Queues */
   1150          
   1151          /********************   Mail Queue Management Functions  ***********************/
   1152          #if (defined (osFeature_MailQ)  &&  (osFeature_MailQ != 0))  /* Use Mail Queues */
   1153          
   1154          
   1155          typedef struct os_mailQ_cb {
   1156            const osMailQDef_t *queue_def;
   1157            QueueHandle_t handle;
   1158            osPoolId pool;
   1159          } os_mailQ_cb_t;
   1160          
   1161          /**
   1162          * @brief Create and Initialize mail queue
   1163          * @param  queue_def     reference to the mail queue definition obtain with \ref osMailQ
   1164          * @param   thread_id     thread ID (obtained by \ref osThreadCreate or \ref osThreadGetId) or NULL.
   1165          * @retval mail queue ID for reference by other functions or NULL in case of error.
   1166          * @note   MUST REMAIN UNCHANGED: \b osMailCreate shall be consistent in every CMSIS-RTOS.
   1167          */
   1168          osMailQId osMailCreate (const osMailQDef_t *queue_def, osThreadId thread_id)
   1169          {
   1170          #if (configSUPPORT_DYNAMIC_ALLOCATION == 1)
   1171            (void) thread_id;
   1172            
   1173            osPoolDef_t pool_def = {queue_def->queue_sz, queue_def->item_sz, NULL};
   1174            
   1175            /* Create a mail queue control block */
   1176          
   1177            *(queue_def->cb) = pvPortMalloc(sizeof(struct os_mailQ_cb));
   1178          
   1179            if (*(queue_def->cb) == NULL) {
   1180              return NULL;
   1181            }
   1182            (*(queue_def->cb))->queue_def = queue_def;
   1183            
   1184            /* Create a queue in FreeRTOS */
   1185            (*(queue_def->cb))->handle = xQueueCreate(queue_def->queue_sz, sizeof(void *));
   1186          
   1187          
   1188            if ((*(queue_def->cb))->handle == NULL) {
   1189              vPortFree(*(queue_def->cb));
   1190              return NULL;
   1191            }
   1192            
   1193            /* Create a mail pool */
   1194            (*(queue_def->cb))->pool = osPoolCreate(&pool_def);
   1195            if ((*(queue_def->cb))->pool == NULL) {
   1196              //TODO: Delete queue. How to do it in FreeRTOS?
   1197              vPortFree(*(queue_def->cb));
   1198              return NULL;
   1199            }
   1200            
   1201            return *(queue_def->cb);
   1202          #else
   1203            return NULL;
   1204          #endif
   1205          }
   1206          
   1207          /**
   1208          * @brief Allocate a memory block from a mail
   1209          * @param  queue_id      mail queue ID obtained with \ref osMailCreate.
   1210          * @param  millisec      timeout value or 0 in case of no time-out.
   1211          * @retval pointer to memory block that can be filled with mail or NULL in case error.
   1212          * @note   MUST REMAIN UNCHANGED: \b osMailAlloc shall be consistent in every CMSIS-RTOS.
   1213          */
   1214          void *osMailAlloc (osMailQId queue_id, uint32_t millisec)
   1215          {
   1216            (void) millisec;
   1217            void *p;
   1218            
   1219            
   1220            if (queue_id == NULL) {
   1221              return NULL;
   1222            }
   1223            
   1224            p = osPoolAlloc(queue_id->pool);
   1225            
   1226            return p;
   1227          }
   1228          
   1229          /**
   1230          * @brief Allocate a memory block from a mail and set memory block to zero
   1231          * @param  queue_id      mail queue ID obtained with \ref osMailCreate.
   1232          * @param  millisec      timeout value or 0 in case of no time-out.
   1233          * @retval pointer to memory block that can be filled with mail or NULL in case error.
   1234          * @note   MUST REMAIN UNCHANGED: \b osMailCAlloc shall be consistent in every CMSIS-RTOS.
   1235          */
   1236          void *osMailCAlloc (osMailQId queue_id, uint32_t millisec)
   1237          {
   1238            uint32_t i;
   1239            void *p = osMailAlloc(queue_id, millisec);
   1240            
   1241            if (p) {
   1242              for (i = 0; i < queue_id->queue_def->item_sz; i++) {
   1243                ((uint8_t *)p)[i] = 0;
   1244              }
   1245            }
   1246            
   1247            return p;
   1248          }
   1249          
   1250          /**
   1251          * @brief Put a mail to a queue
   1252          * @param  queue_id      mail queue ID obtained with \ref osMailCreate.
   1253          * @param  mail          memory block previously allocated with \ref osMailAlloc or \ref osMailCAlloc.
   1254          * @retval status code that indicates the execution status of the function.
   1255          * @note   MUST REMAIN UNCHANGED: \b osMailPut shall be consistent in every CMSIS-RTOS.
   1256          */
   1257          osStatus osMailPut (osMailQId queue_id, void *mail)
   1258          {
   1259            portBASE_TYPE taskWoken;
   1260            
   1261            
   1262            if (queue_id == NULL) {
   1263              return osErrorParameter;
   1264            }
   1265            
   1266            taskWoken = pdFALSE;
   1267            
   1268            if (inHandlerMode()) {
   1269              if (xQueueSendFromISR(queue_id->handle, &mail, &taskWoken) != pdTRUE) {
   1270                return osErrorOS;
   1271              }
   1272              portEND_SWITCHING_ISR(taskWoken);
   1273            }
   1274            else {
   1275              if (xQueueSend(queue_id->handle, &mail, 0) != pdTRUE) { 
   1276                return osErrorOS;
   1277              }
   1278            }
   1279            
   1280            return osOK;
   1281          }
   1282          
   1283          /**
   1284          * @brief Get a mail from a queue
   1285          * @param  queue_id   mail queue ID obtained with \ref osMailCreate.
   1286          * @param millisec    timeout value or 0 in case of no time-out
   1287          * @retval event that contains mail information or error code.
   1288          * @note   MUST REMAIN UNCHANGED: \b osMailGet shall be consistent in every CMSIS-RTOS.
   1289          */
   1290          osEvent osMailGet (osMailQId queue_id, uint32_t millisec)
   1291          {
   1292            portBASE_TYPE taskWoken;
   1293            TickType_t ticks;
   1294            osEvent event;
   1295            
   1296            event.def.mail_id = queue_id;
   1297            
   1298            if (queue_id == NULL) {
   1299              event.status = osErrorParameter;
   1300              return event;
   1301            }
   1302            
   1303            taskWoken = pdFALSE;
   1304            
   1305            ticks = 0;
   1306            if (millisec == osWaitForever) {
   1307              ticks = portMAX_DELAY;
   1308            }
   1309            else if (millisec != 0) {
   1310              ticks = millisec / portTICK_PERIOD_MS;
   1311              if (ticks == 0) {
   1312                ticks = 1;
   1313              }
   1314            }
   1315            
   1316            if (inHandlerMode()) {
   1317              if (xQueueReceiveFromISR(queue_id->handle, &event.value.p, &taskWoken) == pdTRUE) {
   1318                /* We have mail */
   1319                event.status = osEventMail;
   1320              }
   1321              else {
   1322                event.status = osOK;
   1323              }
   1324              portEND_SWITCHING_ISR(taskWoken);
   1325            }
   1326            else {
   1327              if (xQueueReceive(queue_id->handle, &event.value.p, ticks) == pdTRUE) {
   1328                /* We have mail */
   1329                event.status = osEventMail;
   1330              }
   1331              else {
   1332                event.status = (ticks == 0) ? osOK : osEventTimeout;
   1333              }
   1334            }
   1335            
   1336            return event;
   1337          }
   1338          
   1339          /**
   1340          * @brief Free a memory block from a mail
   1341          * @param  queue_id mail queue ID obtained with \ref osMailCreate.
   1342          * @param  mail     pointer to the memory block that was obtained with \ref osMailGet.
   1343          * @retval status code that indicates the execution status of the function.
   1344          * @note   MUST REMAIN UNCHANGED: \b osMailFree shall be consistent in every CMSIS-RTOS.
   1345          */
   1346          osStatus osMailFree (osMailQId queue_id, void *mail)
   1347          {
   1348            if (queue_id == NULL) {
   1349              return osErrorParameter;
   1350            }
   1351            
   1352            return osPoolFree(queue_id->pool, mail);
   1353          }
   1354          #endif  /* Use Mail Queues */
