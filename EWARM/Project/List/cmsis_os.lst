   1633          /**
   1634          * @brief  Create and Initialize a Recursive Mutex
   1635          * @param  mutex_def     mutex definition referenced with \ref osMutex.
   1636          * @retval  mutex ID for reference by other functions or NULL in case of error..
   1637          */
   1638          osMutexId osRecursiveMutexCreate (const osMutexDef_t *mutex_def)
   1639          {
   1640          #if (configUSE_RECURSIVE_MUTEXES == 1)
   1641          #if( configSUPPORT_STATIC_ALLOCATION == 1 ) && ( configSUPPORT_DYNAMIC_ALLOCATION == 1 )
   1642          
   1643            if (mutex_def->controlblock != NULL){
   1644              return xSemaphoreCreateRecursiveMutexStatic( mutex_def->controlblock );
   1645            }
   1646            else {
   1647              return xSemaphoreCreateRecursiveMutex();
   1648            }
   1649          #elif ( configSUPPORT_STATIC_ALLOCATION == 1 )
   1650            return xSemaphoreCreateRecursiveMutexStatic( mutex_def->controlblock );
   1651          #else 
   1652            return xSemaphoreCreateRecursiveMutex();
   1653          #endif
   1654          #else
   1655            return NULL;
   1656          #endif	
   1657          }
   1658          
   1659          /**
   1660          * @brief  Release a Recursive Mutex
   1661          * @param   mutex_id      mutex ID obtained by \ref osRecursiveMutexCreate.
   1662          * @retval  status code that indicates the execution status of the function.
   1663          */
   1664          osStatus osRecursiveMutexRelease (osMutexId mutex_id)
   1665          {
   1666          #if (configUSE_RECURSIVE_MUTEXES == 1)
   1667            osStatus result = osOK;
   1668           
   1669            if (xSemaphoreGiveRecursive(mutex_id) != pdTRUE) 
   1670            {
   1671              result = osErrorOS;
   1672            }
   1673            return result;
   1674          #else
   1675          	return osErrorResource;
   1676          #endif
   1677          }
   1678          
   1679          /**
   1680          * @brief  Release a Recursive Mutex
   1681          * @param   mutex_id    mutex ID obtained by \ref osRecursiveMutexCreate.
   1682          * @param millisec      timeout value or 0 in case of no time-out.
   1683          * @retval  status code that indicates the execution status of the function.
   1684          */
   1685          osStatus osRecursiveMutexWait (osMutexId mutex_id, uint32_t millisec)
   1686          {
   1687          #if (configUSE_RECURSIVE_MUTEXES == 1)
   1688            TickType_t ticks;
   1689            
   1690            if (mutex_id == NULL)
   1691            {
   1692              return osErrorParameter;
   1693            }
   1694            
   1695            ticks = 0;
   1696            if (millisec == osWaitForever) 
   1697            {
   1698              ticks = portMAX_DELAY;
   1699            }
   1700            else if (millisec != 0) 
   1701            {
   1702              ticks = millisec / portTICK_PERIOD_MS;
   1703              if (ticks == 0) 
   1704              {
   1705                ticks = 1;
   1706              }
   1707            }
   1708            
   1709            if (xSemaphoreTakeRecursive(mutex_id, ticks) != pdTRUE) 
   1710            {
   1711              return osErrorOS;
   1712            }
   1713            return osOK;
   1714          #else
   1715          	return osErrorResource;
   1716          #endif
   1717          }
