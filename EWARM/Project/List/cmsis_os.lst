    316          /*********************** Generic Wait Functions *******************************/
    317          /**
    318          * @brief   Wait for Timeout (Time Delay)
    319          * @param   millisec      time delay value
    320          * @retval  status code that indicates the execution status of the function.
    321          */
    322          osStatus osDelay (uint32_t millisec)
    323          {
    324          #if INCLUDE_vTaskDelay
    325            TickType_t ticks = millisec / portTICK_PERIOD_MS;
    326            
    327            vTaskDelay(ticks ? ticks : 1);          /* Minimum delay = 1 tick */
    328            
    329            return osOK;
    330          #else
    331            (void) millisec;
    332            
    333            return osErrorResource;
    334          #endif
    335          }
    336          
    337          #if (defined (osFeature_Wait)  &&  (osFeature_Wait != 0)) /* Generic Wait available */
    338          /**
    339          * @brief  Wait for Signal, Message, Mail, or Timeout
    340          * @param   millisec  timeout value or 0 in case of no time-out
    341          * @retval  event that contains signal, message, or mail information or error code.
    342          * @note   MUST REMAIN UNCHANGED: \b osWait shall be consistent in every CMSIS-RTOS.
    343          */
    344          osEvent osWait (uint32_t millisec);
    345          
    346          #endif  /* Generic Wait available */
    347          
    348          /***********************  Timer Management Functions ***************************/
    349          /**
    350          * @brief  Create a timer.
    351          * @param  timer_def     timer object referenced with \ref osTimer.
    352          * @param  type          osTimerOnce for one-shot or osTimerPeriodic for periodic behavior.
    353          * @param  argument      argument to the timer call back function.
    354          * @retval  timer ID for reference by other functions or NULL in case of error.
    355          * @note   MUST REMAIN UNCHANGED: \b osTimerCreate shall be consistent in every CMSIS-RTOS.
    356          */
    357          osTimerId osTimerCreate (const osTimerDef_t *timer_def, os_timer_type type, void *argument)
    358          {
    359          #if (configUSE_TIMERS == 1)
    360          
    361          #if( ( configSUPPORT_STATIC_ALLOCATION == 1 ) && ( configSUPPORT_DYNAMIC_ALLOCATION == 1 ) ) 
    362            if(timer_def->controlblock != NULL) {
    363              return xTimerCreateStatic((const char *)"",
    364                                1, // period should be filled when starting the Timer using osTimerStart
    365                                (type == osTimerPeriodic) ? pdTRUE : pdFALSE,
    366                                (void *) argument,
    367                                (TimerCallbackFunction_t)timer_def->ptimer,
    368                                (StaticTimer_t *)timer_def->controlblock);
    369            }
    370            else {
    371              return xTimerCreate((const char *)"",
    372                                1, // period should be filled when starting the Timer using osTimerStart
    373                                (type == osTimerPeriodic) ? pdTRUE : pdFALSE,
    374                                (void *) argument,
    375                                (TimerCallbackFunction_t)timer_def->ptimer);
    376           }
    377          #elif( configSUPPORT_STATIC_ALLOCATION == 1 )
    378            return xTimerCreateStatic((const char *)"",
    379                                1, // period should be filled when starting the Timer using osTimerStart
    380                                (type == osTimerPeriodic) ? pdTRUE : pdFALSE,
    381                                (void *) argument,
    382                                (TimerCallbackFunction_t)timer_def->ptimer,
    383                                (StaticTimer_t *)timer_def->controlblock);  
    384          #else
    385            return xTimerCreate((const char *)"",
    386                                1, // period should be filled when starting the Timer using osTimerStart
    387                                (type == osTimerPeriodic) ? pdTRUE : pdFALSE,
    388                                (void *) argument,
    389                                (TimerCallbackFunction_t)timer_def->ptimer);
    390          #endif
    391          
    392          #else 
    393          	return NULL;
    394          #endif
    395          }
    396          
    397          /**
    398          * @brief  Start or restart a timer.
    399          * @param  timer_id      timer ID obtained by \ref osTimerCreate.
    400          * @param  millisec      time delay value of the timer.
    401          * @retval  status code that indicates the execution status of the function
    402          * @note   MUST REMAIN UNCHANGED: \b osTimerStart shall be consistent in every CMSIS-RTOS.
    403          */
    404          osStatus osTimerStart (osTimerId timer_id, uint32_t millisec)
    405          {
    406            osStatus result = osOK;
    407          #if (configUSE_TIMERS == 1)  
    408            portBASE_TYPE taskWoken = pdFALSE;
    409            TickType_t ticks = millisec / portTICK_PERIOD_MS;
    410          
    411            if (ticks == 0)
    412              ticks = 1;
    413              
    414            if (inHandlerMode()) 
    415            {
    416              if (xTimerChangePeriodFromISR(timer_id, ticks, &taskWoken) != pdPASS)
    417              {
    418                result = osErrorOS;
    419              }
    420              else
    421              {
    422                portEND_SWITCHING_ISR(taskWoken);     
    423              }
    424            }
    425            else 
    426            {
    427              if (xTimerChangePeriod(timer_id, ticks, 0) != pdPASS)
    428                result = osErrorOS;
    429            }
    430          
    431          #else 
    432            result = osErrorOS;
    433          #endif
    434            return result;
    435          }
    436          
    437          /**
    438          * @brief  Stop a timer.
    439          * @param  timer_id      timer ID obtained by \ref osTimerCreate
    440          * @retval  status code that indicates the execution status of the function.
    441          * @note   MUST REMAIN UNCHANGED: \b osTimerStop shall be consistent in every CMSIS-RTOS.
    442          */
    443          osStatus osTimerStop (osTimerId timer_id)
    444          {
    445            osStatus result = osOK;
    446          #if (configUSE_TIMERS == 1)  
    447            portBASE_TYPE taskWoken = pdFALSE;
    448          
    449            if (inHandlerMode()) {
    450              if (xTimerStopFromISR(timer_id, &taskWoken) != pdPASS) {
    451                return osErrorOS;
    452              }
    453              portEND_SWITCHING_ISR(taskWoken);
    454            }
    455            else {
    456              if (xTimerStop(timer_id, 0) != pdPASS) {
    457                result = osErrorOS;
    458              }
    459            }
    460          #else 
    461            result = osErrorOS;
    462          #endif 
    463            return result;
    464          }
    465          
    466          /**
    467          * @brief  Delete a timer.
    468          * @param  timer_id      timer ID obtained by \ref osTimerCreate
    469          * @retval  status code that indicates the execution status of the function.
    470          * @note   MUST REMAIN UNCHANGED: \b osTimerDelete shall be consistent in every CMSIS-RTOS.
    471          */
    472          osStatus osTimerDelete (osTimerId timer_id)
    473          {
    474          osStatus result = osOK;
    475          
    476          #if (configUSE_TIMERS == 1)
    477          
    478             if (inHandlerMode()) {
    479               return osErrorISR;
    480            }
    481            else { 
    482              if ((xTimerDelete(timer_id, osWaitForever )) != pdPASS) {
    483                result = osErrorOS;
    484              }
    485            } 
    486              
    487          #else 
    488            result = osErrorOS;
    489          #endif 
    490           
    491            return result;
    492          }
    493          
    494          /***************************  Signal Management ********************************/
    495          /**
    496          * @brief  Set the specified Signal Flags of an active thread.
    497          * @param  thread_id     thread ID obtained by \ref osThreadCreate or \ref osThreadGetId.
    498          * @param  signals       specifies the signal flags of the thread that should be set.
    499          * @retval previous signal flags of the specified thread or 0x80000000 in case of incorrect parameters.
    500          * @note   MUST REMAIN UNCHANGED: \b osSignalSet shall be consistent in every CMSIS-RTOS.
    501          */
    502          int32_t osSignalSet (osThreadId thread_id, int32_t signal)
    503          {
    504          #if( configUSE_TASK_NOTIFICATIONS == 1 )	
    505            BaseType_t xHigherPriorityTaskWoken = pdFALSE;
    506            uint32_t ulPreviousNotificationValue = 0;
    507            
    508            if (inHandlerMode())
    509            {
    510              if(xTaskGenericNotifyFromISR( thread_id , (uint32_t)signal, eSetBits, &ulPreviousNotificationValue, &xHigherPriorityTaskWoken ) != pdPASS )
    511                return 0x80000000;
    512              
    513              portYIELD_FROM_ISR( xHigherPriorityTaskWoken );
    514            }  
    515            else if(xTaskGenericNotify( thread_id , (uint32_t)signal, eSetBits, &ulPreviousNotificationValue) != pdPASS )
    516              return 0x80000000;
    517            
    518            return ulPreviousNotificationValue;
    519          #else
    520            (void) thread_id;
    521            (void) signal;
    522          
    523            return 0x80000000; /* Task Notification not supported */ 	
    524          #endif
    525          }
    526          
    527          /**
    528          * @brief  Clear the specified Signal Flags of an active thread.
    529          * @param  thread_id  thread ID obtained by \ref osThreadCreate or \ref osThreadGetId.
    530          * @param  signals    specifies the signal flags of the thread that shall be cleared.
    531          * @retval  previous signal flags of the specified thread or 0x80000000 in case of incorrect parameters.
    532          * @note   MUST REMAIN UNCHANGED: \b osSignalClear shall be consistent in every CMSIS-RTOS.
    533          */
    534          int32_t osSignalClear (osThreadId thread_id, int32_t signal);
    535          
    536          /**
    537          * @brief  Wait for one or more Signal Flags to become signaled for the current \b RUNNING thread.
    538          * @param  signals   wait until all specified signal flags set or 0 for any single signal flag.
    539          * @param  millisec  timeout value or 0 in case of no time-out.
    540          * @retval  event flag information or error code.
    541          * @note   MUST REMAIN UNCHANGED: \b osSignalWait shall be consistent in every CMSIS-RTOS.
    542          */
    543          osEvent osSignalWait (int32_t signals, uint32_t millisec)
    544          {
    545            osEvent ret;
    546          
    547          #if( configUSE_TASK_NOTIFICATIONS == 1 )
    548          	
    549            TickType_t ticks;
    550          
    551            ret.value.signals = 0;  
    552            ticks = 0;
    553            if (millisec == osWaitForever) {
    554              ticks = portMAX_DELAY;
    555            }
    556            else if (millisec != 0) {
    557              ticks = millisec / portTICK_PERIOD_MS;
    558              if (ticks == 0) {
    559                ticks = 1;
    560              }
    561            }  
    562            
    563            if (inHandlerMode())
    564            {
    565              ret.status = osErrorISR;  /*Not allowed in ISR*/
    566            }
    567            else
    568            {
    569              if(xTaskNotifyWait( 0,(uint32_t) signals, (uint32_t *)&ret.value.signals, ticks) != pdTRUE)
    570              {
    571                if(ticks == 0)  ret.status = osOK;
    572                else  ret.status = osEventTimeout;
    573              }
    574              else if(ret.value.signals < 0)
    575              {
    576                ret.status =  osErrorValue;     
    577              }
    578              else  ret.status =  osEventSignal;
    579            }
    580          #else
    581            (void) signals;
    582            (void) millisec;
    583          	
    584            ret.status =  osErrorOS;	/* Task Notification not supported */
    585          #endif
    586            
    587            return ret;
    588          }
    589          
    590          /****************************  Mutex Management ********************************/
    591          /**
    592          * @brief  Create and Initialize a Mutex object
    593          * @param  mutex_def     mutex definition referenced with \ref osMutex.
    594          * @retval  mutex ID for reference by other functions or NULL in case of error.
    595          * @note   MUST REMAIN UNCHANGED: \b osMutexCreate shall be consistent in every CMSIS-RTOS.
    596          */
    597          osMutexId osMutexCreate (const osMutexDef_t *mutex_def)
    598          {
    599          #if ( configUSE_MUTEXES == 1)
    600          
    601          #if( configSUPPORT_STATIC_ALLOCATION == 1 ) && ( configSUPPORT_DYNAMIC_ALLOCATION == 1 )
    602          
    603            if (mutex_def->controlblock != NULL) {
    604              return xSemaphoreCreateMutexStatic( mutex_def->controlblock );
    605               }
    606            else {
    607              return xSemaphoreCreateMutex(); 
    608            }
    609          #elif ( configSUPPORT_STATIC_ALLOCATION == 1 )
    610            return xSemaphoreCreateMutexStatic( mutex_def->controlblock );
    611          #else  
    612              return xSemaphoreCreateMutex(); 
    613          #endif
    614          #else
    615            return NULL;
    616          #endif
    617          }
    618          
    619          /**
    620          * @brief Wait until a Mutex becomes available
    621          * @param mutex_id      mutex ID obtained by \ref osMutexCreate.
    622          * @param millisec      timeout value or 0 in case of no time-out.
    623          * @retval  status code that indicates the execution status of the function.
    624          * @note   MUST REMAIN UNCHANGED: \b osMutexWait shall be consistent in every CMSIS-RTOS.
    625          */
    626          osStatus osMutexWait (osMutexId mutex_id, uint32_t millisec)
    627          {
    628            TickType_t ticks;
    629            portBASE_TYPE taskWoken = pdFALSE;  
    630            
    631            
    632            if (mutex_id == NULL) {
    633              return osErrorParameter;
    634            }
    635            
    636            ticks = 0;
    637            if (millisec == osWaitForever) {
    638              ticks = portMAX_DELAY;
    639            }
    640            else if (millisec != 0) {
    641              ticks = millisec / portTICK_PERIOD_MS;
    642              if (ticks == 0) {
    643                ticks = 1;
    644              }
    645            }
    646            
    647            if (inHandlerMode()) {
    648              if (xSemaphoreTakeFromISR(mutex_id, &taskWoken) != pdTRUE) {
    649                return osErrorOS;
    650              }
    651          	portEND_SWITCHING_ISR(taskWoken);
    652            } 
    653            else if (xSemaphoreTake(mutex_id, ticks) != pdTRUE) {
    654              return osErrorOS;
    655            }
    656            
    657            return osOK;
    658          }
    659          
    660          /**
    661          * @brief Release a Mutex that was obtained by \ref osMutexWait
    662          * @param mutex_id      mutex ID obtained by \ref osMutexCreate.
    663          * @retval  status code that indicates the execution status of the function.
    664          * @note   MUST REMAIN UNCHANGED: \b osMutexRelease shall be consistent in every CMSIS-RTOS.
    665          */
    666          osStatus osMutexRelease (osMutexId mutex_id)
    667          {
    668            osStatus result = osOK;
    669            portBASE_TYPE taskWoken = pdFALSE;
    670            
    671            if (inHandlerMode()) {
    672              if (xSemaphoreGiveFromISR(mutex_id, &taskWoken) != pdTRUE) {
    673                return osErrorOS;
    674              }
    675              portEND_SWITCHING_ISR(taskWoken);
    676            }
    677            else if (xSemaphoreGive(mutex_id) != pdTRUE) 
    678            {
    679              result = osErrorOS;
    680            }
    681            return result;
    682          }
    683          
    684          /**
    685          * @brief Delete a Mutex
    686          * @param mutex_id  mutex ID obtained by \ref osMutexCreate.
    687          * @retval  status code that indicates the execution status of the function.
    688          * @note   MUST REMAIN UNCHANGED: \b osMutexDelete shall be consistent in every CMSIS-RTOS.
    689          */
    690          osStatus osMutexDelete (osMutexId mutex_id)
    691          {
    692            if (inHandlerMode()) {
    693              return osErrorISR;
    694            }
    695          
    696            vQueueDelete(mutex_id);
    697          
    698            return osOK;
    699          }
