   1491          
   1492          /**
   1493          * @brief  Delay a task until a specified time
   1494          * @param   PreviousWakeTime   Pointer to a variable that holds the time at which the 
   1495          *          task was last unblocked. PreviousWakeTime must be initialised with the current time
   1496          *          prior to its first use (PreviousWakeTime = osKernelSysTick() )
   1497          * @param   millisec    time delay value
   1498          * @retval  status code that indicates the execution status of the function.
   1499          */
   1500          osStatus osDelayUntil (uint32_t *PreviousWakeTime, uint32_t millisec)
   1501          {
   1502          #if INCLUDE_vTaskDelayUntil
   1503            TickType_t ticks = (millisec / portTICK_PERIOD_MS);
   1504            vTaskDelayUntil((TickType_t *) PreviousWakeTime, ticks ? ticks : 1);
   1505            
   1506            return osOK;
   1507          #else
   1508            (void) millisec;
   1509            (void) PreviousWakeTime;
   1510            
   1511            return osErrorResource;
   1512          #endif
   1513          }
   1514          
   1515          /**
   1516          * @brief   Abort the delay for a specific thread
   1517          * @param   thread_id   thread ID obtained by \ref osThreadCreate or \ref osThreadGetId   
   1518          * @retval  status code that indicates the execution status of the function.
   1519          */
   1520          osStatus osAbortDelay(osThreadId thread_id)
   1521          {
   1522          #if INCLUDE_xTaskAbortDelay
   1523            
   1524            xTaskAbortDelay(thread_id);
   1525            
   1526            return osOK;
   1527          #else
   1528            (void) thread_id;
   1529            
   1530            return osErrorResource;
   1531          #endif
   1532          }
