   1356          /*************************** Additional specific APIs to Free RTOS ************/
   1357          /**
   1358          * @brief  Handles the tick increment
   1359          * @param  none.
   1360          * @retval none.
   1361          */
   1362          void osSystickHandler(void)
   1363          {
   1364          
   1365          #if (INCLUDE_xTaskGetSchedulerState  == 1 )
   1366            if (xTaskGetSchedulerState() != taskSCHEDULER_NOT_STARTED)
   1367            {
   1368          #endif  /* INCLUDE_xTaskGetSchedulerState */  
   1369              xPortSysTickHandler();
   1370          #if (INCLUDE_xTaskGetSchedulerState  == 1 )
   1371            }
   1372          #endif  /* INCLUDE_xTaskGetSchedulerState */  
   1373          }
   1374          
   1375          #if ( INCLUDE_eTaskGetState == 1 )
   1376          /**
   1377          * @brief  Obtain the state of any thread.
   1378          * @param   thread_id   thread ID obtained by \ref osThreadCreate or \ref osThreadGetId.
   1379          * @retval  the stae of the thread, states are encoded by the osThreadState enumerated type.
   1380          */
   1381          osThreadState osThreadGetState(osThreadId thread_id)
   1382          {
   1383            eTaskState ThreadState;
   1384            osThreadState result;
   1385            
   1386            ThreadState = eTaskGetState(thread_id);
   1387            
   1388            switch (ThreadState)
   1389            {
   1390            case eRunning :
   1391              result = osThreadRunning;
   1392              break;
   1393            case eReady :
   1394              result = osThreadReady;
   1395              break;
   1396            case eBlocked :
   1397              result = osThreadBlocked;
   1398              break;
   1399            case eSuspended :
   1400              result = osThreadSuspended;
   1401              break;
   1402            case eDeleted :
   1403              result = osThreadDeleted;
   1404              break;
   1405            default:
   1406              result = osThreadError;
   1407            } 
   1408            
   1409            return result;
   1410          }
   1411          #endif /* INCLUDE_eTaskGetState */
   1412          
   1413          #if (INCLUDE_eTaskGetState == 1)
   1414          /**
   1415          * @brief Check if a thread is already suspended or not.
   1416          * @param thread_id thread ID obtained by \ref osThreadCreate or \ref osThreadGetId.
   1417          * @retval status code that indicates the execution status of the function.
   1418          */
   1419          osStatus osThreadIsSuspended(osThreadId thread_id)
   1420          {
   1421            if (eTaskGetState(thread_id) == eSuspended)
   1422              return osOK;
   1423            else
   1424              return osErrorOS;
   1425          }
   1426          #endif /* INCLUDE_eTaskGetState */
   1427          /**
   1428          * @brief  Suspend execution of a thread.
   1429          * @param   thread_id   thread ID obtained by \ref osThreadCreate or \ref osThreadGetId.
   1430          * @retval  status code that indicates the execution status of the function.
   1431          */
   1432          osStatus osThreadSuspend (osThreadId thread_id)
   1433          {
   1434          #if (INCLUDE_vTaskSuspend == 1)
   1435              vTaskSuspend(thread_id);
   1436            
   1437            return osOK;
   1438          #else
   1439            return osErrorResource;
   1440          #endif
   1441          }
   1442          
   1443          /**
   1444          * @brief  Resume execution of a suspended thread.
   1445          * @param   thread_id   thread ID obtained by \ref osThreadCreate or \ref osThreadGetId.
   1446          * @retval  status code that indicates the execution status of the function.
   1447          */
   1448          osStatus osThreadResume (osThreadId thread_id)
   1449          {
   1450          #if (INCLUDE_vTaskSuspend == 1)  
   1451            if(inHandlerMode())
   1452            {
   1453              if (xTaskResumeFromISR(thread_id) == pdTRUE)
   1454              {
   1455                portYIELD_FROM_ISR(pdTRUE);
   1456              }
   1457            }
   1458            else
   1459            {
   1460              vTaskResume(thread_id);
   1461            }
   1462            return osOK;
   1463          #else
   1464            return osErrorResource;
   1465          #endif
   1466          }
   1467          
   1468          /**
   1469          * @brief  Suspend execution of a all active threads.
