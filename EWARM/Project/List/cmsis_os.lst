    135          /*********************** Kernel Control Functions *****************************/
    136          /**
    137          * @brief  Initialize the RTOS Kernel for creating objects.
    138          * @retval status code that indicates the execution status of the function.
    139          * @note   MUST REMAIN UNCHANGED: \b osKernelInitialize shall be consistent in every CMSIS-RTOS.
    140          */
    141          osStatus osKernelInitialize (void);
    142          
    143          /**
    144          * @brief  Start the RTOS Kernel with executing the specified thread.
    145          * @param  thread_def    thread definition referenced with \ref osThread.
    146          * @param  argument      pointer that is passed to the thread function as start argument.
    147          * @retval status code that indicates the execution status of the function
    148          * @note   MUST REMAIN UNCHANGED: \b osKernelStart shall be consistent in every CMSIS-RTOS.
    149          */
    150          osStatus osKernelStart (void)
    151          {
    152            vTaskStartScheduler();
    153            
    154            return osOK;
    155          }
    156          
    157          /**
    158          * @brief  Check if the RTOS kernel is already started
    159          * @param  None
    160          * @retval (0) RTOS is not started
    161          *         (1) RTOS is started
    162          *         (-1) if this feature is disabled in FreeRTOSConfig.h 
    163          * @note  MUST REMAIN UNCHANGED: \b osKernelRunning shall be consistent in every CMSIS-RTOS.
    164          */
    165          int32_t osKernelRunning(void)
    166          {
    167          #if ( ( INCLUDE_xTaskGetSchedulerState == 1 ) || ( configUSE_TIMERS == 1 ) )
    168            if (xTaskGetSchedulerState() == taskSCHEDULER_NOT_STARTED)
    169              return 0;
    170            else
    171              return 1;
    172          #else
    173          	return (-1);
    174          #endif	
    175          }
    176          
    177          #if (defined (osFeature_SysTick)  &&  (osFeature_SysTick != 0))     // System Timer available
    178          /**
    179          * @brief  Get the value of the Kernel SysTick timer
    180          * @param  None
    181          * @retval None
    182          * @note   MUST REMAIN UNCHANGED: \b osKernelSysTick shall be consistent in every CMSIS-RTOS.
    183          */
    184          uint32_t osKernelSysTick(void)
    185          {
    186            if (inHandlerMode()) {
    187              return xTaskGetTickCountFromISR();
    188            }
    189            else {
    190              return xTaskGetTickCount();
    191            }
    192          }
    193          #endif    // System Timer available
    194          /*********************** Thread Management *****************************/
    195          /**
    196          * @brief  Create a thread and add it to Active Threads and set it to state READY.
    197          * @param  thread_def    thread definition referenced with \ref osThread.
    198          * @param  argument      pointer that is passed to the thread function as start argument.
    199          * @retval thread ID for reference by other functions or NULL in case of error.
    200          * @note   MUST REMAIN UNCHANGED: \b osThreadCreate shall be consistent in every CMSIS-RTOS.
    201          */
    202          osThreadId osThreadCreate (const osThreadDef_t *thread_def, void *argument)
    203          {
    204            TaskHandle_t handle;
    205            
    206          #if( configSUPPORT_STATIC_ALLOCATION == 1 ) &&  ( configSUPPORT_DYNAMIC_ALLOCATION == 1 )
    207            if((thread_def->buffer != NULL) && (thread_def->controlblock != NULL)) {
    208              handle = xTaskCreateStatic((TaskFunction_t)thread_def->pthread,(const portCHAR *)thread_def->name,
    209                        thread_def->stacksize, argument, makeFreeRtosPriority(thread_def->tpriority),
    210                        thread_def->buffer, thread_def->controlblock);
    211            }
    212            else {
    213              if (xTaskCreate((TaskFunction_t)thread_def->pthread,(const portCHAR *)thread_def->name,
    214                        thread_def->stacksize, argument, makeFreeRtosPriority(thread_def->tpriority),
    215                        &handle) != pdPASS)  {
    216                return NULL;
    217              } 
    218            }
    219          #elif( configSUPPORT_STATIC_ALLOCATION == 1 )
    220          
    221              handle = xTaskCreateStatic((TaskFunction_t)thread_def->pthread,(const portCHAR *)thread_def->name,
    222                        thread_def->stacksize, argument, makeFreeRtosPriority(thread_def->tpriority),
    223                        thread_def->buffer, thread_def->controlblock);
    224          #else
    225            if (xTaskCreate((TaskFunction_t)thread_def->pthread,(const portCHAR *)thread_def->name,
    226                             thread_def->stacksize, argument, makeFreeRtosPriority(thread_def->tpriority),
    227                             &handle) != pdPASS)  {
    228              return NULL;
    229            }     
    230          #endif
    231            
    232            return handle;
    233          }
    234          
    235          /**
    236          * @brief  Return the thread ID of the current running thread.
    237          * @retval thread ID for reference by other functions or NULL in case of error.
    238          * @note   MUST REMAIN UNCHANGED: \b osThreadGetId shall be consistent in every CMSIS-RTOS.
    239          */
    240          osThreadId osThreadGetId (void)
    241          {
    242          #if ( ( INCLUDE_xTaskGetCurrentTaskHandle == 1 ) || ( configUSE_MUTEXES == 1 ) )
    243            return xTaskGetCurrentTaskHandle();
    244          #else
    245          	return NULL;
    246          #endif
    247          }
    248          
    249          /**
    250          * @brief  Terminate execution of a thread and remove it from Active Threads.
    251          * @param   thread_id   thread ID obtained by \ref osThreadCreate or \ref osThreadGetId.
    252          * @retval  status code that indicates the execution status of the function.
    253          * @note   MUST REMAIN UNCHANGED: \b osThreadTerminate shall be consistent in every CMSIS-RTOS.
    254          */
    255          osStatus osThreadTerminate (osThreadId thread_id)
    256          {
    257          #if (INCLUDE_vTaskDelete == 1)
    258            vTaskDelete(thread_id);
    259            return osOK;
    260          #else
    261            return osErrorOS;
    262          #endif
    263          }
    264          
    265          /**
    266          * @brief  Pass control to next thread that is in state \b READY.
    267          * @retval status code that indicates the execution status of the function.
    268          * @note   MUST REMAIN UNCHANGED: \b osThreadYield shall be consistent in every CMSIS-RTOS.
    269          */
    270          osStatus osThreadYield (void)
    271          {
    272            taskYIELD();
    273            
    274            return osOK;
    275          }
    276          
    277          /**
    278          * @brief   Change priority of an active thread.
    279          * @param   thread_id     thread ID obtained by \ref osThreadCreate or \ref osThreadGetId.
    280          * @param   priority      new priority value for the thread function.
    281          * @retval  status code that indicates the execution status of the function.
    282          * @note   MUST REMAIN UNCHANGED: \b osThreadSetPriority shall be consistent in every CMSIS-RTOS.
    283          */
    284          osStatus osThreadSetPriority (osThreadId thread_id, osPriority priority)
    285          {
    286          #if (INCLUDE_vTaskPrioritySet == 1)
    287            vTaskPrioritySet(thread_id, makeFreeRtosPriority(priority));
    288            return osOK;
    289          #else
    290            return osErrorOS;
    291          #endif
    292          }
    293          
    294          /**
    295          * @brief   Get current priority of an active thread.
    296          * @param   thread_id     thread ID obtained by \ref osThreadCreate or \ref osThreadGetId.
    297          * @retval  current priority value of the thread function.
    298          * @note   MUST REMAIN UNCHANGED: \b osThreadGetPriority shall be consistent in every CMSIS-RTOS.
    299          */
    300          osPriority osThreadGetPriority (osThreadId thread_id)
    301          {
    302          #if (INCLUDE_uxTaskPriorityGet == 1)
    303            if (inHandlerMode())
    304            {
    305              return makeCmsisPriority(uxTaskPriorityGetFromISR(thread_id));  
    306            }
    307            else
    308            {  
    309              return makeCmsisPriority(uxTaskPriorityGet(thread_id));
    310            }
    311          #else
    312            return osPriorityError;
    313          #endif
    314          }
