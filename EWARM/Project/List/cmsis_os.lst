    701          /********************  Semaphore Management Functions **************************/
    702          
    703          #if (defined (osFeature_Semaphore)  &&  (osFeature_Semaphore != 0))
    704          
    705          /**
    706          * @brief Create and Initialize a Semaphore object used for managing resources
    707          * @param semaphore_def semaphore definition referenced with \ref osSemaphore.
    708          * @param count         number of available resources.
    709          * @retval  semaphore ID for reference by other functions or NULL in case of error.
    710          * @note   MUST REMAIN UNCHANGED: \b osSemaphoreCreate shall be consistent in every CMSIS-RTOS.
    711          */
    712          osSemaphoreId osSemaphoreCreate (const osSemaphoreDef_t *semaphore_def, int32_t count)
    713          { 
    714          #if( configSUPPORT_STATIC_ALLOCATION == 1 ) && ( configSUPPORT_DYNAMIC_ALLOCATION == 1 )
    715          
    716            osSemaphoreId sema;
    717            
    718            if (semaphore_def->controlblock != NULL){
    719              if (count == 1) {
    720                return xSemaphoreCreateBinaryStatic( semaphore_def->controlblock );
    721              }
    722              else {
    723          #if (configUSE_COUNTING_SEMAPHORES == 1 )
    724                return xSemaphoreCreateCountingStatic( count, count, semaphore_def->controlblock );
    725          #else
    726                return NULL;
    727          #endif
    728              }
    729            }
    730            else {
    731              if (count == 1) {
    732                vSemaphoreCreateBinary(sema);
    733                return sema;
    734              }
    735              else {
    736          #if (configUSE_COUNTING_SEMAPHORES == 1 )	
    737                return xSemaphoreCreateCounting(count, count);
    738          #else
    739                return NULL;
    740          #endif    
    741              }
    742            }
    743          #elif ( configSUPPORT_STATIC_ALLOCATION == 1 ) // configSUPPORT_DYNAMIC_ALLOCATION == 0
    744            if(count == 1) {
    745              return xSemaphoreCreateBinaryStatic( semaphore_def->controlblock );
    746            }
    747            else
    748            {
    749          #if (configUSE_COUNTING_SEMAPHORES == 1 )
    750                return xSemaphoreCreateCountingStatic( count, count, semaphore_def->controlblock );
    751          #else
    752                return NULL;
    753          #endif    
    754            }
    755          #else  // configSUPPORT_STATIC_ALLOCATION == 0  && configSUPPORT_DYNAMIC_ALLOCATION == 1
    756            osSemaphoreId sema;
    757           
    758            if (count == 1) {
    759              vSemaphoreCreateBinary(sema);
    760              return sema;
    761            }
    762            else {
    763          #if (configUSE_COUNTING_SEMAPHORES == 1 )	
    764              return xSemaphoreCreateCounting(count, count);
    765          #else
    766              return NULL;
    767          #endif
    768            }
    769          #endif
    770          }
    771          
    772          /**
    773          * @brief Wait until a Semaphore token becomes available
    774          * @param  semaphore_id  semaphore object referenced with \ref osSemaphore.
    775          * @param  millisec      timeout value or 0 in case of no time-out.
    776          * @retval  number of available tokens, or -1 in case of incorrect parameters.
    777          * @note   MUST REMAIN UNCHANGED: \b osSemaphoreWait shall be consistent in every CMSIS-RTOS.
    778          */
    779          int32_t osSemaphoreWait (osSemaphoreId semaphore_id, uint32_t millisec)
    780          {
    781            TickType_t ticks;
    782            portBASE_TYPE taskWoken = pdFALSE;  
    783            
    784            
    785            if (semaphore_id == NULL) {
    786              return osErrorParameter;
    787            }
    788            
    789            ticks = 0;
    790            if (millisec == osWaitForever) {
    791              ticks = portMAX_DELAY;
    792            }
    793            else if (millisec != 0) {
    794              ticks = millisec / portTICK_PERIOD_MS;
    795              if (ticks == 0) {
    796                ticks = 1;
    797              }
    798            }
    799            
    800            if (inHandlerMode()) {
    801              if (xSemaphoreTakeFromISR(semaphore_id, &taskWoken) != pdTRUE) {
    802                return osErrorOS;
    803              }
    804          	portEND_SWITCHING_ISR(taskWoken);
    805            }  
    806            else if (xSemaphoreTake(semaphore_id, ticks) != pdTRUE) {
    807              return osErrorOS;
    808            }
    809            
    810            return osOK;
    811          }
    812          
    813          /**
    814          * @brief Release a Semaphore token
    815          * @param  semaphore_id  semaphore object referenced with \ref osSemaphore.
    816          * @retval  status code that indicates the execution status of the function.
    817          * @note   MUST REMAIN UNCHANGED: \b osSemaphoreRelease shall be consistent in every CMSIS-RTOS.
    818          */
    819          osStatus osSemaphoreRelease (osSemaphoreId semaphore_id)
    820          {
    821            osStatus result = osOK;
    822            portBASE_TYPE taskWoken = pdFALSE;
    823            
    824            
    825            if (inHandlerMode()) {
    826              if (xSemaphoreGiveFromISR(semaphore_id, &taskWoken) != pdTRUE) {
    827                return osErrorOS;
    828              }
    829              portEND_SWITCHING_ISR(taskWoken);
    830            }
    831            else {
    832              if (xSemaphoreGive(semaphore_id) != pdTRUE) {
    833                result = osErrorOS;
    834              }
    835            }
    836            
    837            return result;
    838          }
    839          
    840          /**
    841          * @brief Delete a Semaphore
    842          * @param  semaphore_id  semaphore object referenced with \ref osSemaphore.
    843          * @retval  status code that indicates the execution status of the function.
    844          * @note   MUST REMAIN UNCHANGED: \b osSemaphoreDelete shall be consistent in every CMSIS-RTOS.
    845          */
    846          osStatus osSemaphoreDelete (osSemaphoreId semaphore_id)
    847          {
    848            if (inHandlerMode()) {
