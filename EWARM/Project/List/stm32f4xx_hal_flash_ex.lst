   1232            *(__IO uint8_t *)OPTCR_BYTE0_ADDRESS &= (~FLASH_OPTCR_BOR_LEV);
   1233            *(__IO uint8_t *)OPTCR_BYTE0_ADDRESS |= Level;
   1234          
