    480          /**
    481            * @brief  Configures the SysTick clock source.
    482            * @param  CLKSource specifies the SysTick clock source.
    483            *          This parameter can be one of the following values:
    484            *             @arg SYSTICK_CLKSOURCE_HCLK_DIV8: AHB clock divided by 8 selected as SysTick clock source.
    485            *             @arg SYSTICK_CLKSOURCE_HCLK: AHB clock selected as SysTick clock source.
    486            * @retval None
    487            */
    488          void HAL_SYSTICK_CLKSourceConfig(uint32_t CLKSource)
    489          {
    490            /* Check the parameters */
    491            assert_param(IS_SYSTICK_CLK_SOURCE(CLKSource));
    492            if (CLKSource == SYSTICK_CLKSOURCE_HCLK)
    493            {
    494              SysTick->CTRL |= SYSTICK_CLKSOURCE_HCLK;
    495            }
    496            else
    497            {
    498              SysTick->CTRL &= ~SYSTICK_CLKSOURCE_HCLK;
    499            }
    500          }
