    384          /**
    385            * @brief  Gets the priority of an interrupt.
    386            * @param  IRQn External interrupt number.
    387            *         This parameter can be an enumerator of IRQn_Type enumeration
    388            *         (For the complete STM32 Devices IRQ Channels list, please refer to the appropriate CMSIS device file (stm32f4xxxx.h))
    389            * @param   PriorityGroup the priority grouping bits length.
    390            *         This parameter can be one of the following values:
    391            *           @arg NVIC_PRIORITYGROUP_0: 0 bits for preemption priority
    392            *                                      4 bits for subpriority
    393            *           @arg NVIC_PRIORITYGROUP_1: 1 bits for preemption priority
    394            *                                      3 bits for subpriority
    395            *           @arg NVIC_PRIORITYGROUP_2: 2 bits for preemption priority
    396            *                                      2 bits for subpriority
    397            *           @arg NVIC_PRIORITYGROUP_3: 3 bits for preemption priority
    398            *                                      1 bits for subpriority
    399            *           @arg NVIC_PRIORITYGROUP_4: 4 bits for preemption priority
    400            *                                      0 bits for subpriority
    401            * @param  pPreemptPriority Pointer on the Preemptive priority value (starting from 0).
    402            * @param  pSubPriority Pointer on the Subpriority value (starting from 0).
    403            * @retval None
    404            */
    405          void HAL_NVIC_GetPriority(IRQn_Type IRQn, uint32_t PriorityGroup, uint32_t *pPreemptPriority, uint32_t *pSubPriority)
    406          {
    407            /* Check the parameters */
    408            assert_param(IS_NVIC_PRIORITY_GROUP(PriorityGroup));
    409           /* Get priority for Cortex-M system or device specific interrupts */
    410            NVIC_DecodePriority(NVIC_GetPriority(IRQn), PriorityGroup, pPreemptPriority, pSubPriority);
    411          }
