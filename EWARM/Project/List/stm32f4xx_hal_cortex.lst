    210          /**
    211            * @brief  Initiates a system reset request to reset the MCU.
    212            * @retval None
    213            */
    214          void HAL_NVIC_SystemReset(void)
    215          {
    216            /* System Reset */
    217            NVIC_SystemReset();
    218          }
