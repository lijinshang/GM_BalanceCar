    374          /**
    375            * @brief  Gets the priority grouping field from the NVIC Interrupt Controller.
    376            * @retval Priority grouping field (SCB->AIRCR [10:8] PRIGROUP field)
    377            */
    378          uint32_t HAL_NVIC_GetPriorityGrouping(void)
