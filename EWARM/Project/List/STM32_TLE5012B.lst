    402          // 读取更新后的角度旋转次数
    403          errorTypes readUpdAngleRevolution(TLE5012B_Sensor *sensor, int16_t *data)
    404          {
    405          	uint16_t rawData = 0;
    406          
    407          	// 从传感器读取原始数据
    408          	errorTypes status = readFromSensor(sensor, READ_UPD_ANGLE_REV_CMD, &rawData);
    409          
    410          	if (status != NO_ERROR)
    411          	{
    412          		*data = 0; // 如果有错误，返回0
    413          		return status;
    414          	}
    415          
    416          	// 清除低7位
    417          	rawData = (rawData & (DELETE_7BITS));
    418          
    419          	// 检查第9位是否为1
    420          	if (rawData & CHECK_BIT_9)
    421          	{
    422          		// 如果是，则转换为有符号整数
    423          		rawData = rawData - CHANGE_UNIT_TO_INT_9;
    424          	}
    425          
    426          	*data = rawData; // 返回处理后的数据
    427          
    428          	return NO_ERROR;
    429          }
