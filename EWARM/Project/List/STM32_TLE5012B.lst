    691          
    692          float MechAngleToElecAngle(float mech_angle, float offset, int pole_pairs)
    693          {
    694              // 处理无效的极对数输入
    695              if (pole_pairs <= 0) {
    696                  return 0.0f;
    697              }
    698          
    699              // 计算总机械角度（机械角度 + 偏移）
    700              float total_mech = mech_angle + offset;
    701              
    702              // 将总机械角度归一化到[0, 360)范围
    703              total_mech = fmodf(total_mech, 360.0f);
    704              if (total_mech < 0.0f) {
    705                  total_mech += 360.0f;
    706              }
    707              
    708              // 计算电角度 = (总机械角度 × 极对数) mod 360
    709              float elec_angle = fmodf(total_mech * pole_pairs, 360.0f);
    710              
    711              // 确保电角度在[0, 360)范围内
    712              if (elec_angle < 0.0f) {
    713                  elec_angle += 360.0f;
    714              }
    715              
    716              return elec_angle;
    717          }
