    102          // 触发传感器更新 不能在中断里调用
    103          void triggerUpdate(TLE5012B_Sensor *sensor)
    104          {
    105          	// 将SCK引脚设置为低电平
    106          	HAL_GPIO_WritePin(sensor->sck_gpio_port, sensor->sck_pin, GPIO_PIN_RESET);
    107          	// 将MOSI引脚设置为高电平
    108          	HAL_GPIO_WritePin(sensor->mosi_gpio_port, sensor->mosi_pin, GPIO_PIN_SET);
    109          	HAL_GPIO_WritePin(sensor->cs_gpio_port, sensor->cs_pin, GPIO_PIN_RESET); // 使能SPI片选
    110          //	HAL_Delay(1); // 延迟一段时间
    111          	HAL_GPIO_WritePin(sensor->cs_gpio_port, sensor->cs_pin, GPIO_PIN_SET); // 禁用SPI片选
    112          }
    113          
    114          // 重置安全状态
    115          void resetSafety(TLE5012B_Sensor *sensor)
    116          {
    117          	uint16_t u16RegValue = 0;
    118          
    119          //	triggerUpdate(sensor); // 触发更新
    120          
    121          	HAL_GPIO_WritePin(sensor->cs_gpio_port, sensor->cs_pin, GPIO_PIN_RESET); // 使能SPI片选
    122          
    123          	u16RegValue = READ_STA_CMD; // 设置读取状态命令
    124          	HAL_SPI_Transmit(sensor->spi, (uint8_t *)(&u16RegValue), sizeof(u16RegValue) / sizeof(uint16_t), 0xFF); // 发送命令
    125          	u16RegValue = DUMMY; // 设置虚拟值
    126          	HAL_SPI_Transmit(sensor->spi, (uint8_t *)(&u16RegValue), sizeof(u16RegValue) / sizeof(uint16_t), 0xFF); // 发送虚拟值
    127          	HAL_SPI_Transmit(sensor->spi, (uint8_t *)(&u16RegValue), sizeof(u16RegValue) / sizeof(uint16_t), 0xFF); // 再次发送虚拟值
    128          
    129          	HAL_GPIO_WritePin(sensor->cs_gpio_port, sensor->cs_pin, GPIO_PIN_SET); // 禁用SPI片选
    130          }
    131          
    132          // 检查安全状态和CRC校验
    133          errorTypes checkSafety(TLE5012B_Sensor *sensor, uint16_t safety, uint16_t command, uint16_t *readreg, uint16_t length)
    134          {
    135          	errorTypes errorCheck;
    136          
    137          	// 检查系统错误
    138          	if (!((safety) & SYSTEM_ERROR_MASK))
    139          	{
    140          		errorCheck = SYSTEM_ERROR;
    141          	}
    142          	// 检查接口访问错误
    143          	else if (!((safety) & INTERFACE_ERROR_MASK))
    144          	{
    145          		errorCheck = INTERFACE_ACCESS_ERROR;
    146          	}
    147          	// 检查角度值有效性错误
    148          	else if (!((safety) & INV_ANGLE_ERROR_MASK))
    149          	{
    150          		errorCheck = INVALID_ANGLE_ERROR;
    151          	}
    152          	else
    153          	{
    154          		// 计算CRC校验值需要的数据长度
    155          		uint16_t lengthOfTemp = length * 2 + 2;
    156          		// 定义一个临时数组来存储数据
    157          		uint8_t temp[CRC_NUM_REGISTERS*2+2];
    158          
    159          		// 存储命令的高字节和低字节
    160          		temp[0] = _getFirstByte(command);
    161          		temp[1] = _getSecondByte(command);
    162          
    163          		// 存储读取的寄存器值
    164          		for (uint16_t i = 0; i < length; i++)
    165          		{
    166          			temp[2 + 2 * i] = _getFirstByte(readreg[i]);
    167          			temp[2 + 2 * i + 1] = _getSecondByte(readreg[i]);
    168          		}
    169          
    170          		// 获取接收到的CRC校验值
    171          		uint8_t crcReceivedFinal = _getSecondByte(safety);
    172          
    173          		// 计算CRC校验值
    174          		uint8_t crc = _crcCalc(temp, lengthOfTemp);
    175          
    176          		// 比较计算出的CRC校验值和接收到的CRC校验值
    177          		if (crc == crcReceivedFinal)
    178          		{
    179          			errorCheck = NO_ERROR; // 如果一致，则没有错误
    180          		}
    181          		else
    182          		{
    183          			errorCheck = CRC_ERROR; // 如果不一致，则CRC校验错误
    184          			resetSafety(sensor); // 重置安全状态
    185          		}
    186          	}
    187          
    188          	return errorCheck;
    189          }
    190          
    191          // 从传感器读取数据
    192          errorTypes readFromSensor(TLE5012B_Sensor *sensor, uint16_t command, uint16_t *data)
    193          {
    194          	uint16_t safety = 0;
    195          	uint16_t readreg;
    196          	uint16_t u16RegValue = 0;
    197          
    198          	HAL_GPIO_WritePin(sensor->cs_gpio_port, sensor->cs_pin, GPIO_PIN_RESET); // 使能SPI片选
    199          
    200          	u16RegValue = command; // 设置命令
    201          
    202          #ifndef TLE5012_NOT_MODIFY_MOSI_MANUALLY
    203          	// 设置MOSI引脚为复用推挽模式
    204          	TLE5012_SET_MOSI_MODE_AF_PP();
    205          #endif
    206          
    207          	// 发送命令
    208          	HAL_SPI_Transmit(sensor->spi, (uint8_t *)(&u16RegValue), sizeof(u16RegValue) / sizeof(uint16_t), 0xFF);
    209          
    210          #ifndef TLE5012_NOT_MODIFY_MOSI_MANUALLY
    211          	// 设置MOSI引脚为输入模式
    212          	TLE5012_SET_MOSI_MODE_INPUT();
    213          #endif
    214          
    215          	// 接收数据
    216          	HAL_SPI_Receive(sensor->spi, (uint8_t *)(&readreg), 1, 0xFF);
    217          	HAL_SPI_Receive(sensor->spi, (uint8_t *)(&safety), 1, 0xFF);
    218          
    219          	HAL_GPIO_WritePin(sensor->cs_gpio_port, sensor->cs_pin, GPIO_PIN_SET); // 禁用SPI片选
    220          
    221          	// 检查安全状态和CRC校验
    222          	errorTypes checkError = checkSafety(sensor, safety, command, &readreg, 1);
    223          
    224          	if (checkError != NO_ERROR)
    225          	{
    226          		*data = 0; // 如果有错误，返回0
    227          		return checkError;
    228          	}
    229          	else
    230          	{
    231          		*data = readreg; // 如果没有错误，返回读取的数据
    232          		return NO_ERROR;
    233          	}
    234          }
    235          
    236          // 读取多个寄存器的值以计算CRC
    237          errorTypes readBlockCRC(TLE5012B_Sensor *sensor)
    238          {
    239          	uint16_t u16RegValue = 0;
    240          	uint16_t safety = 0;
    241          
    242          	HAL_GPIO_WritePin(sensor->cs_gpio_port, sensor->cs_pin, GPIO_PIN_RESET); // 使能SPI片选
    243          
    244          #ifndef TLE5012_NOT_MODIFY_MOSI_MANUALLY
    245          	// 设置MOSI引脚为复用推挽模式
    246          	TLE5012_SET_MOSI_MODE_AF_PP();
    247          #endif
    248          
    249          	u16RegValue = READ_BLOCK_CRC; // 设置读取块CRC命令
    250          	// 发送命令
    251          	HAL_SPI_Transmit(sensor->spi, (uint8_t *)(&u16RegValue), sizeof(u16RegValue) / sizeof(uint16_t), 0xFFFF);
    252          
    253          #ifndef TLE5012_NOT_MODIFY_MOSI_MANUALLY
    254          	// 设置MOSI引脚为输入模式
    255          	TLE5012_SET_MOSI_MODE_INPUT();
    256          #endif
    257          
    258          	// 接收寄存器数据
    259          	HAL_SPI_Receive(sensor->spi, (uint8_t *)(sensor->registers), CRC_NUM_REGISTERS, 0xFF);
    260          	// 接收安全状态数据
    261          	HAL_SPI_Receive(sensor->spi, (uint8_t *)(&safety), 1, 0xFF);
    262          
    263          	// 检查安全状态和CRC校验
    264          	errorTypes checkError = checkSafety(sensor, safety, READ_BLOCK_CRC, sensor->registers, CRC_NUM_REGISTERS);
    265          
    266          	return checkError;
    267          }
    268          
    269          // 获取角度范围
    270          errorTypes getAngleRange(TLE5012B_Sensor *sensor)
    271          {
    272          	uint16_t rawData = 0;
    273          	// 读取中断模式2
    274          	errorTypes checkError = readFromSensor(sensor, READ_INTMODE_2, &rawData);
    275          
    276          	if (checkError != NO_ERROR)
    277          	{
    278          		return checkError; // 如果有错误，返回错误码
    279          	}
    280          
    281          	// 提取角度范围相关的位
    282          	rawData &= GET_BIT_14_4;
    283          	rawData >>= 4;
    284          
    285          	// 计算角度范围
    286          	sensor->AngleRange = ANGLE_360_VAL * (POW_2_7 / (float)(rawData));
    287          
    288          	return NO_ERROR;
    289          }
    290          
    291          // 读取角度值
    292          errorTypes readAngleValue(TLE5012B_Sensor *sensor, int16_t *data)
    293          {
    294          	uint16_t rawData = 0;
    295          	// 从传感器读取原始数据
    296          	errorTypes status = readFromSensor(sensor, READ_ANGLE_VAL_CMD, &rawData);
    297          
    298          	if (status != NO_ERROR)
    299          	{
    300          		return status; // 如果有错误，返回错误码
    301          	}
    302          
    303          	// 清除第15位
    304          	rawData = (rawData & (DELETE_BIT_15));
    305          
    306          	// 检查第14位是否为1
    307          	if (rawData & CHECK_BIT_14)
    308          	{
    309          		// 如果是，则转换为有符号整数
    310          		rawData = rawData - CHANGE_UINT_TO_INT_15;
    311          	}
    312          
    313          	*data = rawData; // 返回处理后的数据
    314          
    315          	return NO_ERROR;
    316          }
    317          
