     36          	GPIO_InitStruct.Pin			= TLE5012_MOSI_Pin;
     37          	GPIO_InitStruct.Mode		= GPIO_MODE_AF_PP;
     38          	GPIO_InitStruct.Pull		= GPIO_NOPULL;
     39          	GPIO_InitStruct.Speed		= GPIO_SPEED_FREQ_VERY_HIGH;
     40          	GPIO_InitStruct.Alternate	= TLE5012_MOSI_GPIO_ALTERNATE;
     41          	HAL_GPIO_Init(TLE5012_MOSI_GPIO_Port, &GPIO_InitStruct);
     42          }
     43          
