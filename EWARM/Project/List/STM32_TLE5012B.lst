    578          // 获取角度值
    579          errorTypes getAngleValue(TLE5012B_Sensor *sensor)
    580          {
    581          	int16_t rawAnglevalue = 0;
    582          	// 从传感器读取原始角度值
    583          	errorTypes checkError = readAngleValue(sensor, &rawAnglevalue);
    584          
