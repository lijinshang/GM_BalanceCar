    431          // 读取角度旋转次数
    432          errorTypes getNumRevolutions(TLE5012B_Sensor *sensor)
    433          {
    434          	uint16_t rawData = 0;
    435          	// 从传感器读取原始数据
    436          	errorTypes status = readFromSensor(sensor, READ_ANGLE_REV_CMD, &rawData);
    437          
    438          	if (status != NO_ERROR)
    439          	{
    440          		return status; // 如果有错误，返回错误码
    441          	}
    442          
    443          	// 清除低7位
    444          	rawData = (rawData & (DELETE_7BITS));
    445          
    446          	// 检查第9位是否为1
    447          	if (rawData & CHECK_BIT_9)
    448          	{
    449          		// 如果是，则转换为有符号整数
    450          		rawData = rawData - CHANGE_UNIT_TO_INT_9;
    451          	}
    452          
    453          	sensor->NumRev = rawData; // 返回处理后的数据
    454          
    455          	return NO_ERROR;
    456          }
    457          
    458          // 读取温度
    459          errorTypes readTemp(TLE5012B_Sensor *sensor, int16_t *data)
    460          {
    461          	uint16_t rawData = 0;
    462          	// 从传感器读取原始数据
    463          	errorTypes status = readFromSensor(sensor, READ_TEMP_CMD, &rawData);
    464          
    465          	if (status != NO_ERROR)
    466          	{
    467          		*data = 0; // 如果有错误，返回0
    468          		return status;
    469          	}
    470          
    471          	// 清除低7位
    472          	rawData = (rawData & (DELETE_7BITS));
    473          
    474          	// 检查第9位是否为1
    475          	if (rawData & CHECK_BIT_9)
    476          	{
    477          		// 如果是，则转换为有符号整数
    478          		rawData = rawData - CHANGE_UNIT_TO_INT_9;
    479          	}
    480          
    481          	*data = rawData; // 返回处理后的数据
    482          
    483          	return NO_ERROR;
    484          }
    485          
    486          // 计算角度速度
    487          float _calculateAngleSpeed(float angRange, int16_t rawAngleSpeed, uint16_t firMD, uint16_t predictionVal)
    488          {
    489          	float finalAngleSpeed;
    490          	float microsecToSec = 0.000001; // 微秒到秒的转换因子
    491          	float firMDVal;
    492          
    493          	// 根据firMD值设置相应的滤波器系数
    494          	if (firMD == 1)
    495          	{
    496          		firMDVal = 42.7;
    497          	}
    498          	else if (firMD == 0)
    499          	{
    500          		firMDVal = 21.3;
    501          	}
    502          	else if (firMD == 2)
    503          	{
    504          		firMDVal = 85.3;
    505          	}
    506          	else if (firMD == 3)
    507          	{
    508          		firMDVal = 170.6;
    509          	}
    510          	else
    511          	{
    512          		firMDVal = 0;
    513          	}
    514          
    515          	// 计算角度速度
    516          	finalAngleSpeed = ((angRange / POW_2_15) * ((float)rawAngleSpeed)) / (((float)predictionVal) * firMDVal * microsecToSec);
    517          
    518          	return finalAngleSpeed;
    519          }
    520          
    521          // 获取角度速度
    522          errorTypes getAngleSpeed(TLE5012B_Sensor *sensor)
    523          {
    524          	int16_t rawAngleSpeed = 0;
    525          	uint16_t firMDVal = 0;
    526          	uint16_t intMode2Prediction = 0;
    527          
    528          	// 从传感器读取原始角度速度
    529          	errorTypes checkError = readAngleSpeed(sensor, &rawAngleSpeed);
    530          
    531          	if (checkError != NO_ERROR)
    532          	{
    533          		return checkError; // 如果有错误，返回错误码
    534          	}
    535          
    536          	// 获取角度范围
    537          	checkError = getAngleRange(sensor);
    538          
    539          	if (checkError != NO_ERROR)
    540          	{
    541          		return checkError; // 如果有错误，返回错误码
    542          	}
    543          
    544          	// 读取中断模式1
    545          	checkError = readFromSensor(sensor, READ_INTMODE_1, &firMDVal);
    546          
    547          	if (checkError != NO_ERROR)
    548          	{
    549          		return checkError; // 如果有错误，返回错误码
    550          	}
    551          
    552          	firMDVal >>= 14; // 右移14位以获取firMD值
    553          
    554          	// 读取中断模式2
    555          	checkError = readFromSensor(sensor, READ_INTMODE_2, &intMode2Prediction);
    556          
    557          	if (checkError != NO_ERROR)
    558          	{
    559          		return checkError; // 如果有错误，返回错误码
    560          	}
    561          
    562          	// 根据prediction位设置预测值
    563          	if (intMode2Prediction & 0x0004)
    564          	{
    565          		intMode2Prediction = 3;
    566          	}
    567          	else
    568          	{
    569          		intMode2Prediction = 2;
    570          	}
    571          
    572          	// 计算角度速度
    573          	sensor->AngleSpeed = _calculateAngleSpeed(sensor->AngleRange, rawAngleSpeed, firMDVal, intMode2Prediction);
    574          
    575          	return NO_ERROR;
    576          }
