     55          // 获取一个16位数的高字节
     56          uint8_t _getFirstByte(uint16_t twoByteWord)
     57          {
     58          	return (uint8_t)(twoByteWord >> 8U);
     59          }
     60          
     61          // 获取一个16位数的低字节
     62          uint8_t _getSecondByte(uint16_t twoByteWord)
     63          {
     64          	return (uint8_t)twoByteWord;
     65          }
     66          
     67          // 计算CRC8校验值
     68          uint8_t _crc8(uint8_t *data, uint8_t length)
     69          {
     70          	uint32_t crc;
     71          	int16_t i, bit;
     72          
     73          	crc = CRC_SEED; // 初始化CRC校验值
     74          
     75          	for (i = 0; i < length; i++)
     76          	{
     77          		crc ^= data[i];
     78          
     79          		for (bit = 0; bit < 8; bit++)
     80          		{
     81          			if ((crc & 0x80) != 0)
     82          			{
     83          				crc <<= 1;
     84          				crc ^= CRC_POLYNOMIAL; // 如果最高位是1，则进行异或操作
     85          			}
     86          			else
     87          			{
     88          				crc <<= 1; // 如果最高位不是1，只进行左移操作
     89          			}
     90          		}
     91          	}
     92          
     93          	return (~crc); // 返回取反后的CRC校验值
     94          }
     95          
     96          // 计算CRC校验值的包装函数
     97          uint8_t _crcCalc(uint8_t *crcData, uint8_t length)
     98          {
     99          	return _crc8(crcData, length);
    100          }
