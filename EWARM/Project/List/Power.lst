     87          void PowerButtonHandle(void)
     88          {
     89          	if(GetPowerButton())//ИпЕчЦНгааЇ
     90          	{
     91          		if(Power.PowerButtonPressCnt < POWER_BUTTON_PRESS_CNT)
     92          			Power.PowerButtonPressCnt++;
     93          		else
     94          		{
     95          			Power.PowerButtonPressCnt = 0;
     96          			Power.PowerButtonActive = 1;
     97          		}
     98          	}
     99          	else
    100          	{
    101          		Power.PowerButtonPressCnt = 0;
    102          //		Power.PowerButtonActive = 0;
    103          	}
    104          }
    105          
    106          /******************************************************************************
    107          КЏЪ§ЃКШэМўПЊЙиЛњДІРэ
    108          ВЮЪ§ЃКЮо
    109          ЗЕЛиЃКЮо
    110          БИзЂЃК10msЕїгУвЛДЮ
    111          ******************************************************************************/
    112          void PowerHandle(void)
    113          {
    114          	switch(Power.PowerStatus)
    115          	{
    116          		case OFF:
    117          			PowerButtonHandle();
    118          			if(Power.PowerButtonActive)//гааЇ
    119          			{//ПЊЛњ
    120          				PowerOn();
    121          				Power.PowerStatus = ON;
    122          				Power.PowerButtonActive = 0;
    123          				Power.PowerOff = 0;
    124          				BUZZ(1000);
    125          //				//ПЊБГЙт
    126          //				HAL_TIM_PWM_Start(&htim4,TIM_CHANNEL_1);
    127          //				__HAL_TIM_SetCompare(&htim4,TIM_CHANNEL_1,30);
    128          //				osTimerStart(myTimer01Handle,1000*30);
    129          				WaitPowerButtonRelease();//ЕШД§АДМќЪЭЗХ
    130          			}
    131          			break;
    132          		case ON:
    133          			PowerButtonHandle();
    134          			if(Power.PowerButtonActive)//гааЇ
    135          			{//ЙиЛњ
    136          				Power.PowerStatus = OFF;
    137          				Power.PowerButtonActive = 0;
    138          				Power.PowerOff = 1;
    139          				BUZZ(1000);
    140          				
    141          				WaitPowerButtonRelease();//ЕШД§АДМќЪЭЗХ
    142          //				//ЙиБГЙт
    143          //				__HAL_TIM_SetCompare(&htim4,TIM_CHANNEL_1,0);
    144          				PowerOff();
    145          			}
    146          			break;
    147          	}
    148          }
