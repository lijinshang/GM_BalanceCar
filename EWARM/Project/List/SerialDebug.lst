    374          /*********************************************************************************************
    375          函数名：void SerialDebug_DataWaveform(void)
    376          参  数：无
    377          返回值：无
    378          结  果：SerialDebug参数调试-滑块
    379          备  注：帧结束时调用，即连续5ms以上没收到数据时调用
    380          **********************************************************************************************/
    381          void SerialDebug_ParameterDebug(void)
    382          {
    383          	unsigned char i;
    384          
    385          	if (COM6_RX_Buffer[0] == 0xA5 && COM6_RX_Buffer[1] == 0x5A && COM6_RX_Buffer[COM6_RX_Buffer[2] + 1] == 0xAA)
    386          	{
    387          		switch (COM6_RX_Buffer[3])
    388          		{
    389          		case 0xC0:		//滑块
    390          			for (i = 0;i < (COM6_RX_Buffer[2] - 2) / 4;i++)
    391          				Byte2Float(COM6_RX_Buffer, i*4 + 4, &Parameter[i]);
    392          			break;
    393          		case 0xD0:		//按钮
    394          			Button = (unsigned int)COM6_RX_Buffer[4] << 8 | COM6_RX_Buffer[5];
    395          			break;
    396          		default: break;
    397          		}
    398          	}
    399          }

