    123          union
    124          {
    125          	unsigned char floatByte[4];
    126          	float floatValue;
    127          }FloatUnion;
    128          
    129          /*********************************************************************************************
    130          函数名：void Float2Byte(float *FloatValue, unsigned char *Byte, unsigned char Subscript)
    131          参  数：FloatValue:float值
    132          		Byte:数组
    133          		Subscript:指定从数组第几个元素开始写入
    134          返回值：无
    135          结  果：将float数据转成4字节数据并存入指定地址
    136          **********************************************************************************************/
    137          void Float2Byte(float *FloatValue, unsigned char *Byte, unsigned char Subscript)
    138          {
    139          	FloatUnion.floatValue = (float)2;
    140          	
    141          	if(FloatUnion.floatByte[0] == 0)
    142          	{//小端模式
    143          		FloatUnion.floatValue = *FloatValue;
    144          
    145          		Byte[Subscript]     = FloatUnion.floatByte[0];
    146          		Byte[Subscript + 1] = FloatUnion.floatByte[1];
    147          		Byte[Subscript + 2] = FloatUnion.floatByte[2];
    148          		Byte[Subscript + 3] = FloatUnion.floatByte[3];
    149          	}
    150          	else
    151          	{//大端模式
    152          		FloatUnion.floatValue = *FloatValue;
    153          
    154          		Byte[Subscript]     = FloatUnion.floatByte[3];
    155          		Byte[Subscript + 1] = FloatUnion.floatByte[2];
    156          		Byte[Subscript + 2] = FloatUnion.floatByte[1];
    157          		Byte[Subscript + 3] = FloatUnion.floatByte[0];
    158          	}
    159          }
    160          
    161          /*********************************************************************************************
    162          函数名：void Byte2Float(unsigned char *Byte, unsigned char Subscript, float *FloatValue)
    163          参  数：Byte:数组
    164          		Subscript:指定从数组第几个元素开始写入
    165          		FloatValue:float值
    166          返回值：无
    167          结  果：从指定地址将4字节数据转成float数据
    168          **********************************************************************************************/
    169          void Byte2Float(unsigned char *Byte, unsigned char Subscript, float *FloatValue)
    170          {
    171          	FloatUnion.floatByte[0] = Byte[Subscript];
    172          	FloatUnion.floatByte[1] = Byte[Subscript + 1];
    173          	FloatUnion.floatByte[2] = Byte[Subscript + 2];
    174          	FloatUnion.floatByte[3] = Byte[Subscript + 3];
    175          
    176          	*FloatValue = FloatUnion.floatValue;
    177          }
    178          
    179          /*********************************************************************************************
    180          函数名：void SerialDebug_SetChannelData(unsigned char Channel, float Data)
    181          参  数：Channel:选择通道(1-10)
    182          		Data:通道数据
    183          返回值：无
    184          结  果：将待发送通道的浮点数据写入发送缓冲区
    185          **********************************************************************************************/
    186          void SerialDebug_SetChannelData(unsigned char Channel, float Data)
    187          {
    188          	if (Channel > 9) return ;
    189          
    190          	Float2Byte(&Data, SerialDebugBuffer, 4 + Channel * 4);
    191          }
    192          
    193          /*********************************************************************************************
    194          函数名：unsigned char SerialDebug_DataWaveform_Generate(unsigned char Channel_Number)
    195          参  数：Channel_Number:需要发送的通道个数
    196          返回值：返回发送缓冲区数据个数
    197          		返回0表示帧格式生成失败
    198          结  果：SerialDebug数据示波:生成帧数据
    199          **********************************************************************************************/
    200          unsigned char SerialDebug_DataWaveform_Generate(unsigned char Channel_Number)
    201          {
    202          	if (Channel_Number > 10) return 0;		//通道个数大于9，直接跳出
    203          
    204          	SerialDebugBuffer[0] = 0xA5;		//帧头
    205          	SerialDebugBuffer[1] = 0x5A;		//帧头
    206          	SerialDebugBuffer[2] = 3 + Channel_Number * 4;		//本帧包含的字节数，除了起始字节外
    207          	SerialDebugBuffer[3] = 0xA0;		//功能码 数据示波
    208          	SerialDebugBuffer[4 + Channel_Number * 4] = 0xAA;		//帧尾
    209          
    210          	return 4 + Channel_Number * 4 + 1;
    211          }
    212          
    213          /*********************************************************************************************
    214          函数名：unsigned char SerialDebug_ParameterDebug_LED_Generate(void)
    215          参  数：无
    216          返回值：返回发送缓冲区数据个数
    217          结  果：SerialDebug参数调试-LED:生成帧数据
    218          **********************************************************************************************/
    219          unsigned char SerialDebug_ParameterDebug_LED_Generate(void)
    220          {
    221          	SerialDebugBuffer[0] = 0xA5;		//帧头
    222          	SerialDebugBuffer[1] = 0x5A;		//帧头
    223          	SerialDebugBuffer[2] = 0x0B;		//本帧包含的字节数，除了起始字节外
    224          	SerialDebugBuffer[3] = 0xB0;		//功能码 参数调试:LED
    225          
    226          	SerialDebugBuffer[4] = LED_State[0];
    227          	SerialDebugBuffer[5] = LED_State[1];
    228          	SerialDebugBuffer[6] = LED_State[2];
    229          	SerialDebugBuffer[7] = LED_State[3];
    230          	SerialDebugBuffer[8] = LED_State[4];
    231          	SerialDebugBuffer[9] = LED_State[5];
    232          	SerialDebugBuffer[10] = LED_State[6];
    233          	SerialDebugBuffer[11] = LED_State[7];
    234          
    235          	SerialDebugBuffer[12] = 0xAA;		//帧尾
    236          
    237          	return 13;
    238          }
