    242          /*********************************************************************************************
    243          函数名：void SerialDebug_DataWaveform(void)
    244          参  数：无
    245          返回值：无
    246          结  果：SerialDebug数据示波:向数据示波窗体添加一组数据
    247          备  注：推荐100ms调用一次
    248          **********************************************************************************************/
    249          void SerialDebug_DataWaveform(void)
    250          {
    251          	unsigned char i;          
    252          	unsigned char Send_Count; 
    253          	
    254          	//制造数据
    255          #if MODEL == SIN_WAVE		//SIN波形
    256          	SerialDebug_SetChannelData(0, SinTab[count_ch0]);
    257          	SerialDebug_SetChannelData(1, SinTab[count_ch1]);
    258          	SerialDebug_SetChannelData(2, SinTab[count_ch2]);
    259          	SerialDebug_SetChannelData(3, SinTab[count_ch3]);
    260          	SerialDebug_SetChannelData(4, SinTab[count_ch4]);
    261          	SerialDebug_SetChannelData(5, SinTab[count_ch5]);
    262          	SerialDebug_SetChannelData(6, SinTab[count_ch6]);
    263          	SerialDebug_SetChannelData(7, SinTab[count_ch7]);
    264          	SerialDebug_SetChannelData(8, SinTab[count_ch8]);
    265          	SerialDebug_SetChannelData(9, SinTab[count_ch9]);
    266          	
    267          	count_ch0++;
    268          	count_ch1++;
    269          	count_ch2++;
    270          	count_ch3++;
    271          	count_ch4++;
    272          	count_ch5++;
    273          	count_ch6++;
    274          	count_ch7++;
    275          	count_ch8++;
    276          	count_ch9++;
    277          
    278          	if (count_ch0 > 99) count_ch0 = 0;
    279          	if (count_ch1 > 99) count_ch1 = 0;
    280          	if (count_ch2 > 99) count_ch2 = 0;
    281          	if (count_ch3 > 99) count_ch3 = 0;
    282          	if (count_ch4 > 99) count_ch4 = 0;
    283          	if (count_ch5 > 99) count_ch5 = 0;
    284          	if (count_ch6 > 99) count_ch6 = 0;
    285          	if (count_ch7 > 99) count_ch7 = 0;
    286          	if (count_ch8 > 99) count_ch8 = 0;
    287          	if (count_ch9 > 99) count_ch9 = 0;
    288          
    289          #endif
    290          #if MODEL == SELF_DEBUG		//自我调试
    291          	SerialDebug_SetChannelData(0, Parameter[0]);
    292          	SerialDebug_SetChannelData(1, Parameter[1]);
    293          	SerialDebug_SetChannelData(2, Parameter[2]);
    294          	SerialDebug_SetChannelData(3, Parameter[3]);
    295          	SerialDebug_SetChannelData(4, Parameter[4]);
    296          	SerialDebug_SetChannelData(5, Parameter[5]);
    297          	SerialDebug_SetChannelData(6, Parameter[6]);
    298          	SerialDebug_SetChannelData(7, Parameter[7]);
    299          #endif
    300          
    301          #if MODEL == NORMAL		//正常使用
    302          	SerialDebug_SetChannelData(0, 0);		//通道0
    303          	SerialDebug_SetChannelData(1, 0);		//通道1
    304          	SerialDebug_SetChannelData(2, 0);		//通道2
    305          	SerialDebug_SetChannelData(3, 0);		//通道3
    306          	SerialDebug_SetChannelData(4, 0);		//通道4
    307          	SerialDebug_SetChannelData(5, 0);		//通道5
    308          	SerialDebug_SetChannelData(6, 0);		//通道6
    309          	SerialDebug_SetChannelData(7, 0);		//通道7
    310          	SerialDebug_SetChannelData(8, 0);		//通道8
    311          	SerialDebug_SetChannelData(9, 0);		//通道9
    312          #endif
    313          
    314          	//制造数据结束
    315          
    316          	Send_Count = SerialDebug_DataWaveform_Generate(10);		//获取10通道数据帧
    317          
    318          	COM6.TX_Len = 0;
    319          	for ( i = 0 ; i < Send_Count; i++)		//添加到串口发送缓冲区
    320          	{//这里需要改成自己的串口发送函数
