    375          /* USER CODE BEGIN Header_Start_CarSub_Task */
    376          /**
    377          * @brief Function implementing the CarSub_Task thread.
    378          * @param argument: Not used
    379          * @retval None
    380          */
    381          /* USER CODE END Header_Start_CarSub_Task */
    382          void Start_CarSub_Task(void const * argument)
    383          {
    384            /* USER CODE BEGIN Start_CarSub_Task */
    385            /* Infinite loop */
    386          	for(;;)
    387          	{
    388          		TinyFOC1.speed_pid_handler.target = 10;
    389          		TinyFOC2.speed_pid_handler.target = 10;
    390          		TinyFOC_MotorStart(&TinyFOC1);
    391          		TinyFOC_MotorStart(&TinyFOC2);
    392          		osDelay(2000);
    393          		TinyFOC1.speed_pid_handler.target = -10;
    394          		TinyFOC2.speed_pid_handler.target = -10;
    395          		TinyFOC_MotorStart(&TinyFOC1);
    396          		TinyFOC_MotorStart(&TinyFOC2);
    397          		osDelay(2000);
    398          		TinyFOC1.speed_pid_handler.target = 0;
    399          		TinyFOC2.speed_pid_handler.target = 0;
    400          		TinyFOC_MotorStop(&TinyFOC1);
    401          		TinyFOC_MotorStop(&TinyFOC2);
    402          		osDelay(2000);
    403          	}
    404            /* USER CODE END Start_CarSub_Task */
    405          }
