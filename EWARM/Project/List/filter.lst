      5          修改历史：
      6          ******************************************************************************/
      7          #include "TinyFOC_hal.h"
      8          
      9          /******************************************************************************
     10          函数：配置一阶滤波器参数
     11          参数：*param：滤波器结构体, cutoff_freq：截止频率, sample_freq：采样频率
     12          返回：无
     13          ******************************************************************************/
     14          void filter_coefficient_config(Filter_Structure_t *param, float cutoff_freq, float sample_freq) 
     15          {
     16              memset(param, 0, sizeof(Filter_Structure_t));
     17              
     18              const float tau = 1.0f / (2 * M_PI * cutoff_freq); // 使用精确的π值
     19              const float alpha = tau * sample_freq;
     20              const float denom = 1.0f + alpha;
     21              
     22              param->coefficient1 = 1.0f / denom;    // α = 1/(1+τ·fs)
     23              param->coefficient2 = alpha / denom;   // 1 - α = τ·fs/(1+τ·fs)
     24          }
     25          
     26          /******************************************************************************
     27          函数：一阶滤波器
     28          参数：*param：滤波器结构体, value：新值
     29          返回：滤波值
     30          ******************************************************************************/
     31          float filter_update_value(Filter_Structure_t *param, float value) 
     32          {
     33              param->current_result = param->coefficient1 * value + param->coefficient2 * param->last_result;
     34              param->last_result = param->current_result;
     35              return param->current_result;
     36          }

