    307          /**
    308           * This function gets the raw data of the accelerometer
    309           *
    310           * @param dev the pointer of device driver structure
    311           * @param accel the pointer of 3axes structure for receive data
    312           *
    313           * @return the reading status, MPU_OK reprensents  reading the data successfully.
    314           */
    315          static int8_t mpu6xxx_get_accel_raw(mpu6xxx_device *dev, mpu6xxx_3axes *accel)
    316          {
    317          	uint8_t buffer[6];
    318          	int8_t res;
    319          
    320          	res = mpu6xxx_read_regs(dev, MPU6XXX_RA_ACCEL_XOUT_H, 6, buffer);
    321          	if (res != MPU_OK)
    322          	{
    323          		return res;
    324          	}
    325          
    326          	accel->x = ((uint16_t)buffer[0] << 8) + buffer[1];
    327          	accel->y = ((uint16_t)buffer[2] << 8) + buffer[3];
    328          	accel->z = ((uint16_t)buffer[4] << 8) + buffer[5];
    329          
    330          	return MPU_OK;
    331          }
    332          
