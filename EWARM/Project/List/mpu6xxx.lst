    115          /**
    116           * This function writes the value of the register for mpu6xxx
    117           *
    118           * @param dev the pointer of device driver structure
    119           * @param reg the register for mpu6xxx
    120           * @param data value to write
    121           *
    122           * @return the writing status, MPU_OK reprensents  writing the value of the register successfully.
    123           */
    124          static int8_t mpu6xxx_write_reg(mpu6xxx_device *dev, uint8_t reg, uint8_t data)
    125          {
    126          	int8_t res = 0;
    127          #ifdef MPU_USING_I2C
    128          
    129          	I2C1_WriteByte(dev->i2c_addr, reg, &data, 1);
    130          
    131          #endif
    132          #ifdef MPU_USING_SPI
    133          	res = spi_send_then_send(&reg, 1, &data, 1);
    134          #endif
    135          	return res;
    136          }
    137          
    138          /**
    139           * This function reads the value of registers for mpu6xxx
    140           *
    141           * @param dev the pointer of device driver structure
    142           * @param reg the register for mpu6xxx
    143           * @param len number of register
    144           * @param buf read data pointer
    145           *
    146           * @return the reading status, MPU_OK reprensents  reading the value of registers successfully.
    147           */
    148          static int8_t mpu6xxx_read_regs(mpu6xxx_device *dev, uint8_t reg, uint8_t len, uint8_t *buf)
    149          {
    150          	int8_t res = 0;
    151          
    152          #ifdef MPU_USING_SPI
    153          	uint8_t tmp;
    154          #endif
    155          #ifdef MPU_USING_I2C
    156          
    157          	I2C1_ReadByte(dev->i2c_addr, reg, buf, len);
    158          #endif
    159          #ifdef MPU_USING_SPI
    160          	//The first bit of the first byte contains the Read/Write bit and indicates the Read (1) or Write (0) operation.
    161          	tmp = reg | 0x80;
    162          
    163          	res = spi_send_then_recv(&tmp, 1, buf, len);
    164          #endif
    165          	return res;
    166          }
    167          
    168          /**
    169           * This function writes a bit value of registers for mpu6xxx
    170           *
    171           * @param dev the pointer of device driver structure
    172           * @param reg the register for mpu6xxx
    173           * @param bit the position of the register
    174           * @param data value to write
    175           *
    176           * @return the writing status, MPU_OK reprensents  writing a bit value of registers successfully.
    177           */
    178          static int8_t mpu6xxx_write_bit(mpu6xxx_device *dev, uint8_t reg, uint8_t bit, uint8_t data)
    179          {
    180          	uint8_t byte;
    181          	int8_t res;
    182          
    183          	res = mpu6xxx_read_regs(dev, reg, 1, &byte);
    184          	if (res != MPU_OK)
    185          	{
    186          		return res;
    187          	}
    188          
    189          	byte = (data != 0) ? (byte | (1 << bit)) : (byte & ~(1 << bit));
    190          
    191          	return mpu6xxx_write_reg(dev, reg, byte);
    192          }
    193          
    194          /**
    195           * This function reads a bit value of registers for mpu6xxx
    196           *
    197           * @param dev the pointer of device driver structure
    198           * @param reg the register for mpu6xxx
    199           * @param bit the position of the register
    200           * @param data read data pointer
    201           *
    202           * @return the reading status, MPU_OK reprensents  reading a bit value of registers successfully.
    203           */
    204          static int8_t mpu6xxx_read_bit(mpu6xxx_device *dev, uint8_t reg, uint8_t bit, uint8_t *data)
    205          {
    206          	uint8_t byte;
    207          	int8_t res;
    208          
    209          	res = mpu6xxx_read_regs(dev, reg, 1, &byte);
    210          	if (res != MPU_OK)
    211          	{
    212          		return res;
    213          	}
    214          
    215          	*data = byte & (1 << bit);
    216          
    217          	return MPU_OK;
    218          }
    219          
    220          /**
    221           * This function writes multi-bit value of registers for mpu6xxx
    222           *
    223           * @param dev the pointer of device driver structure
    224           * @param reg the register for mpu6xxx
    225           * @param stabit the start position of the register
    226           * @param len number of bits to write
    227           * @param data value to write
    228           *
    229           * @return the writing status, MPU_OK reprensents  writing multi-bit value of registers successfully.
    230           */
    231          static int8_t mpu6xxx_write_bits(mpu6xxx_device *dev, uint8_t reg, uint8_t stabit, uint8_t len, uint8_t data)
    232          {
    233          	uint8_t byte, mask;
    234          	int8_t res;
    235          
    236          	res = mpu6xxx_read_regs(dev, reg, 1, &byte);
    237          	if (res != MPU_OK)
    238          	{
    239          		return res;
    240          	}
    241          
    242          	mask = ((1 << len) - 1) << (stabit - len + 1);
    243          	data <<= (stabit - len + 1); // shift data into correct position
    244          	data &= mask; // zero all non-important bits in data
    245          	byte &= ~(mask); // zero all important bits in existing byte
    246          	byte |= data; // combine data with existing byte
    247          
    248          	return mpu6xxx_write_reg(dev, reg, byte);
    249          }
    250          
    251          /**
    252           * This function reads multi-bit value of registers for mpu6xxx
    253           *
    254           * @param dev the pointer of device driver structure
    255           * @param reg the register for mpu6xxx
    256           * @param stabit the start position of the register
    257           * @param len number of bits to write
    258           * @param data read data pointer
    259           *
    260           * @return the reading status, MPU_OK reprensents  reading multi-bit value of registers successfully.
    261           */
    262          static int8_t mpu6xxx_read_bits(mpu6xxx_device *dev, uint8_t reg, uint8_t stabit, uint8_t len, uint8_t *data)
    263          {
    264          	uint8_t byte, mask;
    265          	int8_t res;
    266          
    267          	res = mpu6xxx_read_regs(dev, reg, 1, &byte);
    268          	if (res != MPU_OK)
    269          	{
    270          		return res;
    271          	}
    272          
    273          	mask = ((1 << len) - 1) << (stabit - len + 1);
    274          	byte &= mask;
    275          	byte >>= (stabit - len + 1);
    276          	*data = byte;
    277          
    278          	return MPU_OK;
    279          }
