    281          // MAG
    282          #ifdef PKG_USING_MPU6XXX_MAG
    283          
    284          #define MAG_READ_DELAY_TIME         50
    285          
    286          static void mpu92_mag_write_reg(mpu6xxx_device *dev, uint8_t addr, uint8_t data)
    287          {
    288          	uint8_t  status = 0;
    289          	uint32_t timeout = MAG_READ_DELAY_TIME;
    290          
    291          	mpu6xxx_write_reg(dev, MPU6XXX_RA_I2C_SLV4_ADDR, AK8963_I2C_ADDR);
    292          	mpu6xxx_write_reg(dev, MPU6XXX_RA_I2C_SLV4_REG, addr);
    293          	mpu6xxx_write_reg(dev, MPU6XXX_RA_I2C_SLV4_DO, data);
    294          	mpu6xxx_write_reg(dev, MPU6XXX_RA_I2C_SLV4_CTRL, MPU6500_I2C_SLVx_EN);
    295          
    296          	do
    297          	{
    298          		mpu6xxx_read_regs(dev, MPU6XXX_RA_I2C_MST_STATUS, 1, &status);
    299          		osDelay(1);
    300          	}
    301          	while (((status & MPU6500_I2C_SLV4_DONE) == 0) && (timeout--));
    302          
    303          }
    304          
    305          #endif // PKG_USING_MPU6XXX_MAG
