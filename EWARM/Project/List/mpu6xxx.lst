    411          /**
    412           * This function gets mpu6xxx parameters.
    413           *
    414           * @param dev the pointer of device driver structure
    415           * @param cmd Configuration item
    416           * @param param read data pointer
    417           *
    418           * @return the reading status, MPU_OK reprensents  reading the data successfully.
    419           */
    420          int8_t mpu6xxx_get_param(mpu6xxx_device *dev, enum mpu6xxx_cmd cmd, uint16_t *param)
    421          {
    422          	uint8_t data = 0;
    423          	int8_t res = MPU_OK;
    424          
    425          	switch (cmd)
    426          	{
    427          	case MPU6XXX_GYRO_RANGE:  /* Gyroscope full scale range */
    428          		res = mpu6xxx_read_bits(dev, MPU6XXX_RA_GYRO_CONFIG, MPU6XXX_GCONFIG_FS_SEL_BIT, MPU6XXX_GCONFIG_FS_SEL_LENGTH, &data);
    429          		*param = data;
    430          		break;
    431          	case MPU6XXX_ACCEL_RANGE: /* Accelerometer full scale range */
    432          		res = mpu6xxx_read_bits(dev, MPU6XXX_RA_ACCEL_CONFIG, MPU6XXX_ACONFIG_AFS_SEL_BIT, MPU6XXX_ACONFIG_AFS_SEL_LENGTH, &data);
    433          		*param = data;
    434          		break;
    435          	case MPU6XXX_DLPF_CONFIG: /* Digital Low Pass Filter */
    436          		res = mpu6xxx_read_bits(dev, MPU6XXX_RA_CONFIG, MPU6XXX_CFG_DLPF_CFG_BIT, MPU6XXX_CFG_DLPF_CFG_LENGTH, &data);
    437          		*param = data;
    438          		break;
    439          	case MPU6XXX_SAMPLE_RATE: /* Sample Rate */
    440          		/* Sample Rate = Gyroscope Output Rate / (1 + SMPLRT_DIV) */
    441          		res = mpu6xxx_read_bits(dev, MPU6XXX_RA_CONFIG, MPU6XXX_CFG_DLPF_CFG_BIT, MPU6XXX_CFG_DLPF_CFG_LENGTH, &data);
    442          		if (res != MPU_OK)
    443          		{
    444          			break;
    445          		}
    446          
    447          		if (data == 0 || data == 7) /* dlpf is disable */
    448          		{
    449          			res = mpu6xxx_read_regs(dev, MPU6XXX_RA_SMPLRT_DIV, 1, &data);
    450          			*param = 8000 / (data + 1);
    451          		}
    452          		else /* dlpf is enable */
    453          		{
    454          			res = mpu6xxx_read_regs(dev, MPU6XXX_RA_SMPLRT_DIV, 1, &data);
    455          			*param = 1000 / (data + 1);
    456          		}
    457          		break;
    458          	case MPU6XXX_SLEEP: /* sleep mode */
    459          		res = mpu6xxx_read_bit(dev, MPU6XXX_RA_PWR_MGMT_1, MPU6XXX_PWR1_SLEEP_BIT, &data);
    460          		*param = data;
    461          		break;
    462          	}
    463          
    464          	return res;
    465          }
    466          
    467          /**
    468           * This function set mpu6xxx parameters.
    469           *
    470           * @param dev the pointer of device driver structure
    471           * @param cmd Configuration item
    472           * @param param Configuration item parameter
    473           *
    474           * @return the setting status, MPU_OK reprensents  setting the parameter successfully.
    475           */
    476          int8_t mpu6xxx_set_param(mpu6xxx_device *dev, enum mpu6xxx_cmd cmd, uint16_t param)
    477          {
    478          	uint8_t data = 0;
    479          	int8_t res = MPU_OK;
    480          
    481          //    RT_ASSERT(dev);
    482          
    483          	switch (cmd)
    484          	{
    485          	case MPU6XXX_GYRO_RANGE:  /* Gyroscope full scale range */
    486          		res = mpu6xxx_write_bits(dev, MPU6XXX_RA_GYRO_CONFIG, MPU6XXX_GCONFIG_FS_SEL_BIT, MPU6XXX_GCONFIG_FS_SEL_LENGTH, param);
    487          		break;
    488          	case MPU6XXX_ACCEL_RANGE: /* Accelerometer full scale range */
    489          		res = mpu6xxx_write_bits(dev, MPU6XXX_RA_ACCEL_CONFIG, MPU6XXX_ACONFIG_AFS_SEL_BIT, MPU6XXX_ACONFIG_AFS_SEL_LENGTH, param);
    490          		break;
    491          	case MPU6XXX_DLPF_CONFIG: /* Digital Low Pass Filter */
    492          		res = mpu6xxx_write_bits(dev, MPU6XXX_RA_CONFIG, MPU6XXX_CFG_DLPF_CFG_BIT, MPU6XXX_CFG_DLPF_CFG_LENGTH, param);
    493          		break;
    494          	case MPU6XXX_SAMPLE_RATE: /* Sample Rate = 16-bit unsigned value.
    495                                           Sample Rate = [1000 -  4]HZ when dlpf is enable
    496                                           Sample Rate = [8000 - 32]HZ when dlpf is disable */
    497          
    498          		//Sample Rate = Gyroscope Output Rate / (1 + SMPLRT_DIV)
    499          		res = mpu6xxx_read_bits(dev, MPU6XXX_RA_CONFIG, MPU6XXX_CFG_DLPF_CFG_BIT, MPU6XXX_CFG_DLPF_CFG_LENGTH, &data);
    500          		if (res != MPU_OK)
    501          		{
    502          			break;
    503          		}
    504          
    505          		if (data == 0 || data == 7) /* dlpf is disable */
    506          		{
    507          			if (param > 8000)
    508          				data = 0;
    509          			else if (param < 32)
    510          				data = 0xFF;
    511          			else
    512          				data = 8000 / param - 1;
    513          		}
    514          		else /* dlpf is enable */
    515          		{
    516          			if (param > 1000)
    517          				data = 0;
    518          			else if (param < 4)
    519          				data = 0xFF;
    520          			else
    521          				data = 1000 / param - 1;
    522          		}
    523          		res = mpu6xxx_write_reg(dev, MPU6XXX_RA_SMPLRT_DIV, data);
    524          		break;
    525          	case MPU6XXX_SLEEP: /* Configure sleep mode */
    526          		res = mpu6xxx_write_bit(dev, MPU6XXX_RA_PWR_MGMT_1, MPU6XXX_PWR1_SLEEP_BIT, param);
    527          		break;
    528          	}
    529          
    530          	return res;
    531          }
    532          
    533          /**
    534           * This function gets the data of the accelerometer, unit: mg
    535           *
    536           * @param dev the pointer of device driver structure
    537           * @param accel the pointer of 3axes structure for receive data
    538           *
    539           * @return the reading status, MPU_OK reprensents  reading the data successfully.
    540           */
    541          int8_t mpu6xxx_get_accel(mpu6xxx_device *dev)
    542          {
    543          	mpu6xxx_3axes tmp;
    544          	int8_t res;
    545          
    546          	res = mpu6xxx_get_accel_raw(dev, &tmp);
    547          	if (res != MPU_OK)
    548          	{
    549          		return res;
    550          	}
    551          
    552          	//gŁ¨ÖŘÁ¦ĽÓËŮ¶ČµĄÎ»Ł¬1g = 9.8 m/s2Ł©
    553          	dev->accel.x = (float)tmp.x / MPU6XXX_ACCEL_SEN;
    554          	dev->accel.y = (float)tmp.y / MPU6XXX_ACCEL_SEN;
    555          	dev->accel.z = (float)tmp.z / MPU6XXX_ACCEL_SEN;
    556          
    557          	return MPU_OK;
    558          }
    559          
    560          /**
    561           * This function gets the data of the gyroscope, unit: deg/10s
    562           * Here deg/10s means 10 times higher precision than deg/s.
    563           *
    564           * @param dev the pointer of device driver structure
    565           * @param gyro the pointer of 3axes structure for receive data
    566           *
    567           * @return the reading status, MPU_OK reprensents  reading the data successfully.
    568           */
    569          int8_t mpu6xxx_get_gyro(mpu6xxx_device *dev)
    570          {
    571          	mpu6xxx_3axes tmp;
    572          	int8_t res;
    573          
    574          	res = mpu6xxx_get_gyro_raw(dev, &tmp);
    575          	if (res != MPU_OK)
    576          	{
    577          		return res;
    578          	}
    579          
    580          	// µĄÎ»ŁşdpsŁ¨¶Č/ĂëŁ©
    581          	dev->gyro.x = (float)tmp.x / MPU6XXX_GYRO_SEN;
    582          	dev->gyro.y = (float)tmp.y / MPU6XXX_GYRO_SEN;
    583          	dev->gyro.z = (float)tmp.z / MPU6XXX_GYRO_SEN;
    584          
    585          	return MPU_OK;
    586          }
    587          
    588          #ifdef PKG_USING_MPU6XXX_MAG
    589          
    590          /**
    591           * This function gets the data of the magnetometer, unit: uT
    592           *
    593           * @param dev the pointer of device driver structure
    594           * @param gyro the pointer of 3axes structure for receive data
    595           *
    596           * @return the reading status, MPU_OK reprensents  reading the data successfully.
    597           */
    598          int8_t mpu6xxx_get_mag(mpu6xxx_device *dev)
    599          {
    600          	mpu6xxx_3axes tmp;
    601          	int8_t res;
    602          
    603          	res = mpu6xxx_get_mag_raw(dev, &tmp);
    604          	if (res != MPU_OK)
    605          	{
    606          		return res;
    607          	}
    608          
    609          	//µĄÎ»ŁşÎ˘ĚŘËąŔ­ (¦ĚT)
    610          	dev->mag.x = ((int32_t)tmp.x * AK8963_RANGE) / AK8963_FULLSCALE;
    611          	dev->mag.y = ((int32_t)tmp.y * AK8963_RANGE) / AK8963_FULLSCALE;
    612          	dev->mag.z = ((int32_t)tmp.z * AK8963_RANGE) / AK8963_FULLSCALE;
    613          
    614          	return MPU_OK;
    615          }
    616          
    617          #endif
    618          
    619          /**
    620           * This function gets the data of the temperature, unit: Centigrade
    621           *
    622           * @param dev the pointer of device driver structure
    623           * @param temp read data pointer
    624           *
    625           * @return the reading status, MPU_OK reprensents  reading the data successfully.
    626           */
    627          int8_t mpu6xxx_get_temp(mpu6xxx_device *dev)
    628          {
    629          	int16_t tmp;
    630          	int8_t res;
    631          
    632          	res = mpu6xxx_get_temp_raw(dev, &tmp);
    633          	if (res != MPU_OK)
    634          	{
    635          		return res;
    636          	}
    637          
    638          	if (dev->id == MPU6050_WHO_AM_I)
    639          	{
    640          		/* mpu60x0: Temperature in degrees C = (TEMP_OUT Register Value as a signed quantity)/340 + 36.53 */
    641          		dev->temp = (float)tmp / MPU60X0_TEMP_SEN + MPU60X0_TEMP_OFFSET;
    642          	}
    643          	else
    644          	{
    645          		/* mpu6500:  ((TEMP_OUT - RoomTemp_Offset)/Temp_Sensitivity)+ 21degC */
    646          		dev->temp = (float)tmp / MPU6500_TEMP_SEN + MPU6500_TEMP_OFFSET;
    647          	}
    648          
    649          	return MPU_OK;
    650          }
    651          
    652          /**
    653          * This function sets the offset of the accelerometer
    654           *
    655           * @param dev the pointer of device driver structure
    656           * @param offset the pointer of 3axes structure of offsets
    657           *
    658           * @return the setting status, MPU_OK reprensents  setting the offsets successfully.
    659           */
    660          int8_t mpu6xxx_set_accel_offset(mpu6xxx_device *dev, mpu6xxx_3axes *offset)
    661          {
    662          	int8_t res=0;
    663          	res |= mpu6xxx_write_reg(dev, MPU6XXX_RA_XA_OFFS_H, (offset->x)>>8);
    664          	res |= mpu6xxx_write_reg(dev, MPU6XXX_RA_XA_OFFS_L_TC, (offset->x)&0x00ff);
    665          	res |= mpu6xxx_write_reg(dev, MPU6XXX_RA_YA_OFFS_H, (offset->y)>>8);
    666          	res |= mpu6xxx_write_reg(dev, MPU6XXX_RA_YA_OFFS_L_TC, (offset->y)&0x00ff);
    667          	res |= mpu6xxx_write_reg(dev, MPU6XXX_RA_ZA_OFFS_H, (offset->z)>>8);
    668          	res |= mpu6xxx_write_reg(dev, MPU6XXX_RA_ZA_OFFS_L_TC, (offset->z)&0x00ff);
    669          	return res;
    670          }
    671          
    672          /**
    673          * This function gets the offset of the accelerometer
    674           *
    675           * @param dev the pointer of device driver structure
    676           * @param offset the pointer of 3axes structure of offsets
    677           *
    678           * @return the setting status, MPU_OK reprensents  reading the offsets successfully.
    679           */
    680          int8_t mpu6xxx_get_accel_offset(mpu6xxx_device *dev, mpu6xxx_3axes *offset)
    681          {
    682          	uint8_t buffer[6];
    683          	int8_t res;
    684          
    685          	res = mpu6xxx_read_regs(dev, MPU6XXX_RA_XA_OFFS_H, 6, buffer);
    686          	if (res != MPU_OK)
    687          	{
    688          		return res;
    689          	}
    690          
    691          	offset->x = ((uint16_t)buffer[0] << 8) + buffer[1];
    692          	offset->y = ((uint16_t)buffer[2] << 8) + buffer[3];
    693          	offset->z = ((uint16_t)buffer[4] << 8) + buffer[5];
    694          
    695          	return MPU_OK;
    696          }
    697          
    698          /**
    699          * This function sets the offset of the gyroscope
    700           *
    701           * @param dev the pointer of device driver structure
    702           * @param offset the pointer of 3axes structure of offsets
    703           *
    704           * @return the setting status, MPU_OK reprensents  setting the offsets successfully.
    705           */
    706          int8_t mpu6xxx_set_gyro_offset(mpu6xxx_device *dev, mpu6xxx_3axes *offset)
    707          {
    708          	int8_t res=0;
    709          	res |= mpu6xxx_write_reg(dev, MPU6XXX_RA_XG_OFFS_USRH, (offset->x)>>8);
    710          	res |= mpu6xxx_write_reg(dev, MPU6XXX_RA_XG_OFFS_USRL, (offset->x)&0x00ff);
    711          	res |= mpu6xxx_write_reg(dev, MPU6XXX_RA_YG_OFFS_USRH, (offset->y)>>8);
    712          	res |= mpu6xxx_write_reg(dev, MPU6XXX_RA_YG_OFFS_USRL, (offset->y)&0x00ff);
    713          	res |= mpu6xxx_write_reg(dev, MPU6XXX_RA_ZG_OFFS_USRH, (offset->z)>>8);
    714          	res |= mpu6xxx_write_reg(dev, MPU6XXX_RA_ZG_OFFS_USRL, (offset->z)&0x00ff);
    715          	return res;
    716          }
    717          
    718          /**
    719          * This function gets the offset of the gyroscope
    720           *
    721           * @param dev the pointer of device driver structure
    722           * @param offset the pointer of 3axes structure of offsets
    723           *
    724           * @return the setting status, MPU_OK reprensents  reading the offsets successfully.
    725           */
    726          int8_t mpu6xxx_get_gyro_offset(mpu6xxx_device *dev, mpu6xxx_3axes *offset)
    727          {
    728          	uint8_t buffer[6];
    729          	int8_t res;
    730          
    731          	res = mpu6xxx_read_regs(dev, MPU6XXX_RA_XG_OFFS_USRH, 6, buffer);
    732          	if (res != MPU_OK)
    733          	{
    734          		return res;
    735          	}
    736          
    737          	offset->x = ((uint16_t)buffer[0] << 8) + buffer[1];
    738          	offset->y = ((uint16_t)buffer[2] << 8) + buffer[3];
    739          	offset->z = ((uint16_t)buffer[4] << 8) + buffer[5];
    740          
    741          	return MPU_OK;
    742          }
