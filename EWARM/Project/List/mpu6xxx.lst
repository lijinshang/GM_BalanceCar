    387          /**
    388           * This function gets the raw data of the temperature
    389           *
    390           * @param dev the pointer of device driver structure
    391           * @param temp read data pointer
    392           *
    393           * @return the reading status, MPU_OK reprensents  reading the data successfully.
    394           */
    395          static int8_t mpu6xxx_get_temp_raw(mpu6xxx_device *dev, int16_t *temp)
    396          {
    397          	uint8_t buffer[2];
    398          	int8_t res;
    399          
    400          	res = mpu6xxx_read_regs(dev, MPU6XXX_RA_TEMP_OUT_H, 2, buffer);
    401          	if (res != MPU_OK)
    402          	{
    403          		return res;
    404          	}
    405          
    406          	*temp = ((uint16_t)buffer[0] << 8) + buffer[1];
    407          
    408          	return MPU_OK;
    409          }
