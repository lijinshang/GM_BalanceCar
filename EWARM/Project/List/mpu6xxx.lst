    859          //ÖÜĆÚ2-5ms
    860          int roll,pitch,yaw;
    861          void mpu6xxx_get_calc(mpu6xxx_device *dev)
    862          {
    863          	mpu_3axes accel, gyro;
    864          	mpu_3axes EulerAngles;
    865          
    866          	//µĄÎ»Łşg
    867          	accel.x = (float)dev->accel.x;
    868          	accel.y = (float)dev->accel.y;
    869          	accel.z = (float)dev->accel.z;
    870          
    871          	//µĄÎ»Łş»ˇ¶Č/Ăë
    872          	gyro.x = (float)dev->gyro.x*DEG_TO_RAD;
    873          	gyro.y = (float)dev->gyro.y*DEG_TO_RAD;
    874          	gyro.z = (float)dev->gyro.z*DEG_TO_RAD;
    875          
    876          	EulerAngles = IMU_AttitudeAlgorithm(accel, gyro);
    877          
    878          	dev->EulerAngles_Roll = EulerAngles.x;
    879          	dev->EulerAngles_Pitch = EulerAngles.y;
    880          	dev->EulerAngles_Yaw = EulerAngles.z;
    881          
    882          	roll = EulerAngles.x;
    883          	pitch = EulerAngles.y;
    884          	yaw = EulerAngles.z;
    885          }
