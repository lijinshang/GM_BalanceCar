    744          /**
    745           * This function initialize the mpu6xxx device.
    746           *
    747           * @param dev_name the name of transfer device
    748           * @param param the i2c device address for i2c communication, NULL for spi
    749           *
    750           * @return the pointer of device driver structure, NULL reprensents  initialization failed.
    751           */
    752          void mpu6xxx_init(mpu6xxx_device *dev)
    753          {
    754          	uint8_t reg = 0xFF, res = MPU_OK;
    755          
    756          	HAL_Delay(50);
    757          	
    758          	if (mpu6xxx_read_regs(dev, MPU6XXX_RA_WHO_AM_I, 1, &reg) != MPU_OK)
    759          	{
    760          //        LOG_E("Failed to read device id!");
    761          		return;
    762          	}
    763          
    764          	dev->id = reg;
    765          
    766          	switch (dev->id)
    767          	{
    768          	case MPU6050_WHO_AM_I:
    769          //        LOG_I("Find device: mpu6050!");
    770          		break;
    771          	case MPU6500_WHO_AM_I:
    772          //        LOG_I("Find device: mpu6500!");
    773          		break;
    774          	case MPU9250_WHO_AM_I:
    775          //        LOG_I("Find device: mpu9250!");
    776          		break;
    777          	case ICM20608G_WHO_AM_I:
    778          	case ICM20608D_WHO_AM_I:
    779          //        LOG_I("Find device: icm20608!");
    780          		break;
    781          	case 0xFF:
    782          //        LOG_E("No device connection!");
    783          		return;
    784          	default:
    785          //        LOG_W("Unknown device id: 0x%x!", reg);
    786          		mpu6xxx_write_reg(dev, MPU6XXX_RA_PWR_MGMT_1, 0x80); // ´Ą·˘¸´Î»
    787          		HAL_Delay(100);
    788          		break;
    789          	}
    790          
    791          	res += mpu6xxx_write_bits(dev, MPU6XXX_RA_PWR_MGMT_1, MPU6XXX_PWR1_CLKSEL_BIT, MPU6XXX_PWR1_CLKSEL_LENGTH, MPU6XXX_CLOCK_PLL_XGYRO);
    792          	res += mpu6xxx_set_param(dev, MPU6XXX_ACCEL_RANGE, MPU6XXX_ACCEL_RANGE_4G);//ĽÓËŮ¶ČĽĆÁżłĚĹäÖĂ 0.00012g
    793          	res += mpu6xxx_set_param(dev, MPU6XXX_GYRO_RANGE, MPU6XXX_GYRO_RANGE_250DPS);//ÍÓÂÝŇÇÁżłĚĹäÖĂ 0.06¶Č
    794          	res += mpu6xxx_set_param(dev, MPU6XXX_DLPF_CONFIG, MPU6XXX_DLPF_42HZ);//µÍÍ¨ÂË˛¨
    795          	res += mpu6xxx_set_param(dev, MPU6XXX_SAMPLE_RATE, 500);//˛ÉŃůĆµÂĘ 4-1000Hz 500Hz:2ms
    796          	res += mpu6xxx_set_param(dev, MPU6XXX_SLEEP, MPU6XXX_SLEEP_DISABLE);
    797          
    798          #ifdef PKG_USING_MPU6XXX_MAG
    799          	mpu6xxx_write_reg(dev, MPU6XXX_RA_USER_CTRL, 0x20);
    800          	mpu92_mag_write_reg(dev, AK8963_REG_CNTL2, 0x01);      /* [0]  Reset Device                  */
    801          	osDelay(1);
    802          	mpu92_mag_write_reg(dev, AK8963_REG_CNTL1, 0x00);      /* [1]  Power-down mode               */
    803          	mpu92_mag_write_reg(dev, AK8963_REG_CNTL1, 0x0F);      /* [2]  Fuse ROM access mode          */
    804          	mpu92_mag_write_reg(dev, AK8963_REG_CNTL1, 0x00);      /* [3]  Power-down mode               */
    805          	osDelay(1);    // 100us
    806          	mpu92_mag_write_reg(dev, AK8963_REG_CNTL1, 0x16);      /* [4]  16bits and Continuous measurement mode 2 */
    807          
    808          	/* config mpu9250 i2c */
    809          	osDelay(2);
    810          	mpu6xxx_write_reg(dev, MPU6XXX_RA_I2C_MST_CTRL, 0x5D);
    811          	osDelay(2);
    812          	mpu6xxx_write_reg(dev, MPU6XXX_RA_I2C_SLV0_ADDR, AK8963_I2C_ADDR | 0x80);
    813          	osDelay(2);
    814          	mpu6xxx_write_reg(dev, MPU6XXX_RA_I2C_SLV0_REG, AK8963_REG_ST1);
    815          	osDelay(2);
    816          	mpu6xxx_write_reg(dev, MPU6XXX_RA_I2C_SLV0_CTRL, MPU6500_I2C_SLVx_EN | 8);
    817          	osDelay(2);
    818          	mpu6xxx_write_reg(dev, MPU6XXX_RA_I2C_SLV4_CTRL, 0x09);
    819          	osDelay(2);
    820          	mpu6xxx_write_reg(dev, MPU6XXX_RA_I2C_MST_DELAY_CTRL, 0x81);
    821          #endif
    822          
    823          	if (res == MPU_OK)
    824          	{
    825          //        LOG_I("Device init succeed!");
    826          	}
    827          	else
    828          	{
    829          //        LOG_W("Error in device initialization!");
    830          	}
    831          	return;
    832          }
