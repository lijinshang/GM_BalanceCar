     56          #ifdef MPU_USING_SPI
     57          /*********************************************************************************************
     58          şŻĘýĂűŁşSPI·˘ËÍ˝ÓĘŐşŻĘý
     59          ˛Î  ĘýŁşsend_buf:·˘ËÍ»şłĺ send_length:·˘ËÍł¤¶Č
     60          		recv_buf:˝ÓĘŐ»şłĺ recv_length:˝ÓĘŐł¤¶Č
     61          ·µ»ŘÖµŁşres:MPU_OK
     62          **********************************************************************************************/
     63          int8_t spi_send_then_recv(uint8_t *send_buf, uint8_t send_length, uint8_t *recv_buf, uint8_t recv_length)
     64          {
     65          	int8_t res = MPU_OK;
     66          	uint16_t i;
     67          
     68          	MPU_CS_WRITE(0);
     69          
     70          	for(i=0; i<send_length; i++)
     71          	{
     72          		SPI3_ReadWriteByte(*send_buf);
     73          		send_buf++;
     74          	}
     75          	for(i=0; i<recv_length; i++)
     76          	{
     77          		*recv_buf = SPI3_ReadWriteByte(0x00);
     78          		recv_buf++;
     79          	}
     80          	MPU_CS_WRITE(1);
     81          
     82          	return res;
     83          }
     84          /*********************************************************************************************
     85          şŻĘýĂűŁşSPIÁ¬ĐřÁ˝´Î·˘ËÍşŻĘý
     86          ˛Î  ĘýŁşsend_buf1:·˘ËÍ»şłĺ1 send_length1:·˘ËÍł¤¶Č1
     87          		send_buf2:·˘ËÍ»şłĺ2 send_length2:·˘ËÍł¤¶Č2
     88          ·µ»ŘÖµŁşres:MPU_OK
     89          **********************************************************************************************/
     90          int8_t spi_send_then_send(uint8_t *send_buf1, uint8_t send_length1, uint8_t *send_buf2, uint8_t send_length2)
     91          {
     92          	int8_t res = MPU_OK;
     93          	uint16_t i;
     94          
     95          	MPU_CS_WRITE(0);
     96          
     97          	for(i=0; i<send_length1; i++)
     98          	{
     99          		SPI3_ReadWriteByte(*send_buf1);
    100          		send_buf1++;
    101          	}
    102          	for(i=0; i<send_length2; i++)
    103          	{
    104          		SPI3_ReadWriteByte(*send_buf2);
    105          		send_buf2++;
    106          	}
    107          	MPU_CS_WRITE(1);
    108          
    109          //	spi_send_then_recv(send_buf1,send_length1,NULL,0);
    110          //	spi_send_then_recv(send_buf2,send_length2,NULL,0);
    111          	return res;
    112          }
    113          #endif
